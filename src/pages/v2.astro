<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/logo-positivo.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Aimar & Deborah — 12 · 09 · 2026 · Palacio de Murguia, Astigarraga" />
  <title>Aimar & Deborah · Cálida Elegante</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,200;0,300;0,400;0,500;1,200;1,300&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- VERSION NAV -->
  <div class="vn">
    <a href="/" class="vn-back">← propuestas</a>
    <div class="vn-pills">
      <a href="/v1" class="vn-pill">01 Clásica</a>
      <a href="/v2" class="vn-pill vn-active">02 Cálida</a>
      <a href="/v3" class="vn-pill">03 Romántica</a>
    </div>
  </div>

  <!-- NAV -->
  <nav>
    <img src="/logo-positivo.png" alt="A&D monogram" class="nav-logo" />
  </nav>

  <!-- HERO (de V1: foto a pantalla completa, texto centrado) -->
  <section class="hero">
    <div class="hero-image-wrap">
      <img src="/foto.jpeg" alt="Aimar y Deborah" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <p class="hero-pre">os invitamos a nuestra boda</p>
      <h1 class="hero-names">Aimar <span class="amp">&</span> Deborah</h1>
      <p class="hero-date">12 · 09 · 2026</p>
      <p class="hero-venue">Palacio de Murguia, Astigarraga</p>
    </div>
    <div class="hero-scroll"><span class="scroll-line"></span></div>
  </section>

  <!-- VINYL: sticky container que crea el runway de scroll -->
  <div class="vinyl-sticky-container" id="invitacion">
    <section class="invitacion">
      <div class="vinyl-scene-bg"></div>
      <!-- .vinyl-box: el marco circular del que el disco "escapa" al hacer scroll -->
      <div class="vinyl-box">
        <!-- .vinyl-escape-wrapper: controla el scale scroll-driven (independiente de la rotación) -->
        <div class="vinyl-escape-wrapper">
        <div class="vinyl-record">
          <div class="vinyl-grooves"></div>
          <div class="vinyl-label">
            <div class="vinyl-label-inner">
              <p>Dicen que las mejores canciones nacen de mezclas inesperadas. Dos estilos distintos, dos formas de ser y una canción que encaja a la perfección.</p>
              <p>Después de un tiempo sonando juntos, hemos decidido que esta canción dure para siempre.</p>
              <p class="vinyl-cta">Dale al play con nosotros el</p>
              <p class="vinyl-date-small">12 · 09 · 2026</p>
              <div class="vinyl-hole"></div>
            </div>
          </div>
        </div>
        </div> <!-- /vinyl-escape-wrapper -->
      </div> <!-- /vinyl-box -->
    </section>
  </div>

  <!-- DETALLES (de V3: tarjetas blancas con foto polaroid) -->
  <section class="detalles" id="detalles">
    <h2 class="section-title reveal">La celebración</h2>
    <div class="deco-line reveal" style="transition-delay:0.1s"></div>
    <div class="detalles-grid">
      <div class="det-card reveal" style="transition-delay:0.15s">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
        </div>
        <h3>Fecha</h3>
        <p class="det-main">12 de septiembre</p>
        <p class="det-sec">Sábado · 2026</p>
      </div>
      <div class="det-card det-card-center reveal" style="transition-delay:0.25s">
        <div class="det-photo-small">
          <img src="/foto.jpeg" alt="Aimar y Deborah" />
        </div>
      </div>
      <div class="det-card reveal" style="transition-delay:0.2s">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 3"/>
          </svg>
        </div>
        <h3>Hora</h3>
        <p class="det-main">13:30 h</p>
        <p class="det-sec">de la tarde</p>
      </div>
      <div class="det-card det-lugar reveal" style="transition-delay:0.3s">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M12 21s-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-8 12-8 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
        </div>
        <h3>Lugar</h3>
        <p class="det-main">Palacio de Murguia</p>
        <p class="det-sec">Nagusia Kalea, 15 · Astigarraga, Gipuzkoa</p>
      </div>
    </div>
  </section>

  <!-- MAPA (de V3: dos columnas texto + iframe) -->
  <section class="mapa" id="mapa">
    <div class="mapa-inner reveal">
      <div class="mapa-text">
        <h2 class="section-title" style="text-align:left;">Cómo llegar</h2>
        <div class="deco-line" style="margin-left:0;"></div>
        <p class="mapa-addr">Nagusia Kalea, 15<br/>20115 Astigarraga<br/>Gipuzkoa</p>
        <a href="https://maps.google.com/?q=Nagusia+Kalea+15,+20115+Astigarraga" target="_blank" rel="noopener noreferrer" class="mapa-btn">
          Abrir en Google Maps →
        </a>
      </div>
      <div class="mapa-embed">
        <iframe
          src="https://maps.google.com/maps?q=Palacio+de+Murguia,+Astigarraga,+Gipuzkoa&t=&z=16&ie=UTF8&iwloc=&output=embed"
          allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          title="Palacio de Murguia"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- RSVP (de V3: fondo oscuro con foto, tarjetas de contacto) -->
  <section class="rsvp" id="confirmacion">
    <div class="rsvp-photo-bg"></div>
    <div class="rsvp-inner reveal">
      <img src="/logo-negativo.png" alt="A&D" class="rsvp-monogram" />
      <h2 class="rsvp-title">¿Contamos contigo?</h2>
      <p class="rsvp-dead">Confírmanos tu asistencia antes del <strong>10 de agosto</strong></p>
      <div class="rsvp-contacts">
        <a href="tel:+34634421876" class="rsvp-card">
          <span class="rsvp-name">Aimar</span>
          <span class="rsvp-phone">634 421 876</span>
        </a>
        <a href="tel:+34644455703" class="rsvp-card">
          <span class="rsvp-name">Deborah</span>
          <span class="rsvp-phone">644 455 703</span>
        </a>
      </div>
    </div>
  </section>

  <footer>
    <p>Aimar & Deborah · 12 · 09 · 2026</p>
    <p class="footer-sub">deborahyaimar.com</p>
  </footer>

<script>
  // ── SNAP TO STRAIGHT ──────────────────────────────────────────
  const disc = document.querySelector('.vinyl-record') as HTMLElement;
  const SPIN_MS = 20000;
  let spinStart = Date.now();
  let snapActive = false;

  function currentAngle() {
    return ((Date.now() - spinStart) % SPIN_MS) / SPIN_MS * 360;
  }
  function snapStraight() {
    if (snapActive) return;
    snapActive = true;
    const angle = currentAngle();
    disc.style.animation = 'none';
    disc.style.transform = `rotate(${angle}deg)`;
    void disc.offsetWidth;
    const target = angle <= 180 ? 0 : 360;
    disc.style.transition = 'transform 0.9s cubic-bezier(0.33, 1, 0.68, 1)';
    disc.style.transform = `rotate(${target}deg)`;
  }
  function resumeSpin() {
    if (!snapActive) return;
    snapActive = false;
    disc.style.transition = 'none';
    disc.style.transform = 'rotate(0deg)';
    void disc.offsetWidth;
    disc.style.animation = `spin ${SPIN_MS}ms linear infinite`;
    spinStart = Date.now();
  }
  disc.addEventListener('mouseenter', snapStraight);
  disc.addEventListener('mouseleave', resumeSpin);
  disc.addEventListener('touchstart', snapStraight, { passive: true });
  disc.addEventListener('touchend',   resumeSpin,   { passive: true });

  // ── VINYL ESCAPE ON SCROLL ────────────────────────────────────
  const stickyContainer = document.querySelector('.vinyl-sticky-container') as HTMLElement;
  const sceneBg         = document.querySelector('.vinyl-scene-bg')         as HTMLElement;
  const vinylBox        = document.querySelector('.vinyl-box')               as HTMLElement;
  const escapeWrapper   = document.querySelector('.vinyl-escape-wrapper')    as HTMLElement;

  // easing suave
  function ease(t: number) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

  function updateEscape() {
    const rect      = stickyContainer.getBoundingClientRect();
    const maxScroll = stickyContainer.offsetHeight - window.innerHeight;
    const progress  = Math.max(0, Math.min(1, -rect.top / maxScroll));

    // — Fondo oscuro desaparece: 0.35 → 0.75
    const bgP = Math.max(0, Math.min(1, (progress - 0.35) / 0.40));
    sceneBg.style.opacity = String(1 - ease(bgP));

    // — Marco circular (vinyl-box border) desaparece: 0.10 → 0.50
    const boxP = Math.max(0, Math.min(1, (progress - 0.10) / 0.40));
    const borderAlpha = 0.35 * (1 - ease(boxP));
    vinylBox.style.setProperty('--box-alpha', String(borderAlpha));

    // — Vinilo crece: empieza en 0.55, llega a 1.0 entre 0.10 y 0.65
    const scaleP = Math.max(0, Math.min(1, (progress - 0.10) / 0.55));
    const scale  = 0.55 + 0.45 * ease(scaleP);
    escapeWrapper.style.transform = `scale(${scale})`;
  }

  window.addEventListener('scroll', updateEscape, { passive: true });
  updateEscape();

  // ── FADE-IN DE SECCIONES ──────────────────────────────────────
  const fadeEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  fadeEls.forEach(el => io.observe(el));
</script>

</body>
</html>

<style is:global>
  @font-face {
    font-family: 'Sloop';
    src: url('/fonts/Sloop-ScriptThree.ttf') format('truetype');
    font-weight: normal;
    font-display: swap;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAF8F4;
    --blush: #F5E5ED;
    --rose: #E8C5D2;
    --rosewood: #7A3B50;
    --pink: #F2B3CE;
    --pink-label: #F4BCCE;
    --dark: #1a1a1a;
    --gray: #8a7070;
    --border: #e6d8dc;
    --gray-light: #ede8e4;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--dark);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.65;
    letter-spacing: 0.03em;
    -webkit-font-smoothing: antialiased;
  }

  /* VERSION NAV */
  .vn {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(250,248,244,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    font-size: 0.7rem; letter-spacing: 0.12em;
  }

  .vn-back { color: var(--gray); text-decoration: none; transition: color 0.2s; }
  .vn-back:hover { color: var(--dark); }
  .vn-pills { display: flex; gap: 0.4rem; }

  .vn-pill {
    text-decoration: none; padding: 0.3rem 0.8rem;
    border-radius: 100px; border: 1px solid var(--border);
    color: var(--gray); font-size: 0.68rem; letter-spacing: 0.1em;
    transition: all 0.2s;
  }
  .vn-pill:hover { border-color: var(--pink); color: var(--dark); }
  .vn-active { background: var(--rosewood); border-color: var(--rosewood); color: #fff !important; }

  /* NAV */
  nav {
    position: fixed; top: 42px; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: center; padding: 1rem;
    mix-blend-mode: multiply;
  }
  .nav-logo { width: 36px; opacity: 0.7; }

  /* HERO */
  .hero {
    position: relative; height: 100svh; min-height: 600px;
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .hero-image-wrap { position: absolute; inset: 0; }
  .hero-img {
    width: 100%; height: 100%; object-fit: cover; object-position: center 30%;
    filter: grayscale(10%) brightness(0.68);
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(26,10,14,0.1) 0%,
      rgba(26,10,14,0.25) 50%,
      rgba(26,10,14,0.6) 100%
    );
  }
  .hero-content {
    position: relative; z-index: 2;
    text-align: center; color: #fff; padding: 2rem;
  }
  .hero-pre {
    font-size: 0.75rem; letter-spacing: 0.3em;
    text-transform: uppercase; font-weight: 200;
    margin-bottom: 1.25rem; opacity: 0.8;
  }
  .hero-names {
    font-family: 'Sloop', cursive;
    font-size: clamp(4rem, 13vw, 9.5rem);
    font-weight: normal; line-height: 1;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.2);
  }
  .hero-names .amp { font-size: 0.7em; opacity: 0.8; margin: 0 0.05em; }
  .hero-date {
    font-size: 0.9rem; letter-spacing: 0.35em;
    font-weight: 200; margin-bottom: 0.5rem;
  }
  .hero-venue {
    font-size: 0.75rem; letter-spacing: 0.18em;
    text-transform: uppercase; opacity: 0.7; font-weight: 200;
  }
  .hero-scroll {
    position: absolute; bottom: 2.5rem;
    left: 50%; transform: translateX(-50%); z-index: 2;
  }
  .scroll-line {
    display: block; width: 1px; height: 55px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.5));
    animation: scrollFade 2s ease-in-out infinite;
  }
  @keyframes scrollFade {
    0%, 100% { opacity: 0; transform: scaleY(0.1) translateY(-10px); }
    60% { opacity: 1; transform: scaleY(1) translateY(0); }
  }

  /* VINYL */
  .vinyl-sticky-container {
    height: 300vh;
    position: relative;
    /* el fondo del body (--cream) queda visible cuando el scene-bg desaparece */
  }

  .invitacion {
    position: sticky;
    top: 42px; /* justo debajo del version nav */
    height: calc(100vh - 42px);
    display: flex; justify-content: center; align-items: center;
    overflow: hidden;
    padding: 0;
  }

  .vinyl-scene-bg {
    position: absolute; inset: 0;
    background: var(--dark);
    pointer-events: none;
    z-index: 0;
    will-change: opacity;
  }

  /* Marco circular del que "escapa" el disco */
  .vinyl-box {
    --box-alpha: 0.35;
    position: relative; z-index: 1;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, var(--box-alpha));
    padding: 2.5rem;
    box-shadow:
      0 0 0 8px rgba(255,255,255, calc(var(--box-alpha) * 0.15)),
      0 0 60px rgba(255,255,255, calc(var(--box-alpha) * 0.05));
    will-change: border-color, box-shadow;
  }

  /* Controla el scale — independiente de la rotación del disco */
  .vinyl-escape-wrapper {
    will-change: transform;
    transform-origin: center center;
  }
  .vinyl-record {
    position: relative;
    width: clamp(300px, 72vw, 580px);
    aspect-ratio: 1; border-radius: 50%;
    background: radial-gradient(circle at 48% 48%, #2a2a2a, #111 40%, #080808 70%);
    box-shadow: 0 0 0 2px #2a2a2a, inset 0 0 50px rgba(0,0,0,0.9), 0 24px 80px rgba(0,0,0,0.7);
    animation: spin 20s linear infinite;
    cursor: pointer;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .vinyl-grooves {
    position: absolute; inset: 7%; border-radius: 50%;
    background: repeating-radial-gradient(
      circle at center,
      transparent 0px, transparent 5px,
      rgba(255,255,255,0.025) 5px, rgba(255,255,255,0.025) 6px
    );
  }
  .vinyl-label {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 50%; aspect-ratio: 1; border-radius: 50%;
    background: var(--pink-label);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .vinyl-label::before {
    content: '';
    position: absolute; inset: 0;
    background: url('/logo-negativo.png') center / 55% no-repeat;
    opacity: 0.15;
  }
  .vinyl-label-inner {
    position: relative; text-align: center;
    width: 80%;
    font-size: clamp(0.58rem, 1.45vw, 0.82rem);
    color: #111; line-height: 1.45;
    padding-top: 1.5rem;
  }
  .vinyl-label-inner p { margin-bottom: 0.3em; }
  .vinyl-cta { margin-top: 0.5em !important; font-style: italic; opacity: 0.75; }
  .vinyl-date-small { font-weight: 600 !important; letter-spacing: 0.1em; font-size: 1.1em; }
  .vinyl-hole {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 8px; height: 8px;
    background: #111; border-radius: 50%;
  }

  @media (max-width: 500px) {
    .vinyl-label { width: 64%; }
    .vinyl-label-inner {
      width: 82%; padding-top: 0;
      font-size: 0.6rem; line-height: 1.35;
    }
    .vinyl-label-inner p { margin-bottom: 0.2em; }
    .vinyl-cta { margin-top: 0.35em !important; }
  }

  /* REVEAL FADE-IN */
  .reveal {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }

  /* SECTION TITLE */
  .section-title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 200; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--dark);
    text-align: center; margin-bottom: 1rem;
  }
  .deco-line {
    width: 50px; height: 1px;
    background: var(--pink); margin: 0 auto 3.5rem;
  }

  /* DETALLES */
  /* padding-top generoso: el vinilo flota sobre este fondo antes de que empiece el contenido */
  .detalles { background: var(--cream); padding: 8rem 2rem 5rem; }

  .detalles-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    max-width: 700px; margin: 0 auto;
  }

  .det-lugar { grid-column: 1 / -1; }

  .det-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 3px; padding: 2rem 1.5rem; text-align: center;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .det-card:hover {
    box-shadow: 0 6px 30px rgba(122,59,80,0.1);
    transform: translateY(-2px);
  }
  .det-card-center {
    padding: 0; border: none; background: transparent; overflow: hidden;
  }
  .det-photo-small {
    width: 120px; height: 100%; min-height: 140px;
    border: 5px solid #fff;
    box-shadow: 0 4px 20px rgba(26,10,14,0.14);
    transform: rotate(1.5deg); overflow: hidden; border-radius: 1px;
  }
  .det-photo-small img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 20%;
  }
  .det-icon-wrap { display: flex; justify-content: center; margin-bottom: 1rem; }
  .det-icon-wrap svg { width: 24px; height: 24px; color: var(--pink); }
  .det-card h3 {
    font-size: 0.62rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--gray);
    font-weight: 400; margin-bottom: 0.6rem;
  }
  .det-main {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--dark); font-weight: 300;
    letter-spacing: 0.04em; line-height: 1.3; margin-bottom: 0.25rem;
  }
  .det-sec { font-size: 0.75rem; color: var(--gray); font-weight: 200; letter-spacing: 0.06em; }

  /* MAPA */
  .mapa { background: var(--blush); padding: 5rem 5vw; }
  .mapa-inner {
    display: grid; grid-template-columns: 1fr 2fr;
    gap: 3.5rem; max-width: 1100px; align-items: center;
  }
  .mapa-addr {
    font-size: 0.88rem; color: var(--gray);
    line-height: 1.9; margin-bottom: 2rem; font-weight: 200;
  }
  .mapa-btn {
    display: inline-block; font-size: 0.72rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--rosewood); text-decoration: none; font-weight: 400;
    border-bottom: 1px solid var(--rosewood); padding-bottom: 2px;
    transition: opacity 0.2s;
  }
  .mapa-btn:hover { opacity: 0.65; }
  .mapa-embed {
    border-radius: 3px; overflow: hidden; aspect-ratio: 4/3;
    border: 6px solid #fff;
    box-shadow: 0 8px 40px rgba(26,10,14,0.1);
  }
  .mapa-embed iframe { width: 100%; height: 100%; border: 0; display: block; }

  /* RSVP */
  .rsvp {
    background: var(--dark); padding: 7rem 2rem;
    text-align: center; position: relative; overflow: hidden;
  }
  .rsvp-photo-bg {
    position: absolute; inset: 0;
    background: url('/foto.jpeg') center / cover;
    opacity: 0.07; filter: grayscale(100%);
  }
  .rsvp-inner { position: relative; z-index: 1; max-width: 580px; margin: 0 auto; }
  .rsvp-monogram { width: 48px; filter: invert(1); opacity: 0.35; margin-bottom: 2rem; }
  .rsvp-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 200; letter-spacing: 0.2em;
    text-transform: uppercase; color: #fff; margin-bottom: 1rem;
  }
  .rsvp-dead {
    font-size: 0.85rem; color: rgba(255,255,255,0.5);
    margin-bottom: 3rem; font-weight: 200; letter-spacing: 0.06em;
  }
  .rsvp-dead strong { color: var(--rose); font-weight: 300; }
