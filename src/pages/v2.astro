<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/logo-positivo.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Aimar & Deborah — 12 · 09 · 2026 · Palacio de Murguia, Astigarraga" />
  <title>Aimar & Deborah · Cálida Elegante</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,200;0,300;0,400;0,500;1,200;1,300&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- VERSION NAV -->
  <div class="vn">
    <a href="/" class="vn-back">← propuestas</a>
    <div class="vn-pills">
      <a href="/v1" class="vn-pill">01 Clásica</a>
      <a href="/v2" class="vn-pill vn-active">02 Cálida</a>
      <a href="/v3" class="vn-pill">03 Romántica</a>
    </div>
  </div>

  <!-- NAV -->
  <nav>
    <img src="/logo-positivo.png" alt="A&D monogram" class="nav-logo" />
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-image-wrap">
      <img src="/foto.jpeg" alt="Aimar y Deborah" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <p class="hero-pre">os invitamos a nuestra boda</p>
      <h1 class="hero-names">Aimar <span class="amp">&</span> Deborah</h1>
      <p class="hero-date">12 · 09 · 2026</p>
      <p class="hero-venue">Palacio de Murguia, Astigarraga</p>
    </div>
    <div class="hero-scroll"><span class="scroll-line"></span></div>
  </section>

  <!-- FUNDA + VINILO ─────────────────────────────────────────── -->
  <!--
    Capas dentro de .sleeve-scene (stacking context de .invitacion):
      z:1  .sleeve-back  — cara posterior de la funda (plana, oscura)
      z:2→5 .vinyl-riser — el disco: sube por detrás de la portada,
                           pasa a z:5 cuando la funda ya es invisible
      z:3  .sleeve-front — portada (foto + texto): enmascara el disco
                           mientras está dentro de la funda
  -->
  <div class="vinyl-sticky-container" id="invitacion">
    <section class="invitacion">
      <div class="vinyl-scene-bg"></div>

      <div class="sleeve-scene">

        <!-- CARA POSTERIOR de la funda -->
        <div class="sleeve-back" id="sleeveBack"></div>

        <!-- DISCO VINILO (empieza en z:2, detrás de la portada) -->
        <div class="vinyl-riser" id="vinylRiser">
          <div class="vinyl-record" id="vinylDisc">
            <div class="vinyl-grooves"></div>
            <div class="vinyl-label">
              <div class="vinyl-label-inner">
                <p>Dicen que las mejores canciones nacen de mezclas inesperadas. Dos estilos distintos, dos formas de ser y una canción que encaja a la perfección.</p>
                <p>Después de un tiempo sonando juntos, hemos decidido que esta canción dure para siempre.</p>
                <p class="vinyl-cta">Dale al play con nosotros el</p>
                <p class="vinyl-date-small">12 · 09 · 2026</p>
                <div class="vinyl-hole"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- PORTADA de la funda: diseño inspirado en el sobre real -->
        <div class="sleeve-front" id="sleeveFront">
          <!-- Foto de la pareja (lado derecho, como en el PDF) -->
          <div class="sf-photo">
            <img src="/foto.jpeg" alt="Aimar y Deborah" />
          </div>
          <!-- Borde superior abierto (sombra interior que sugiere la ranura de entrada) -->
          <div class="sf-top-shadow"></div>
          <!-- Nombres en script (esquina superior derecha, sobre la foto) -->
          <p class="sf-script">Aimar <span class="sf-amp">&</span> Deborah</p>
          <!-- Datos (esquina inferior izquierda, en el espacio blanco) -->
          <div class="sf-info">
            <p class="sf-date">12 · 09 · 2026</p>
            <p class="sf-venue">Palacio de Murguia</p>
          </div>
          <!-- Monograma (esquina inferior derecha) -->
          <img src="/logo-positivo.png" alt="A&D" class="sf-mono" />
        </div>

      </div><!-- /sleeve-scene -->
    </section>
  </div>

  <!-- DETALLES -->
  <section class="detalles" id="detalles">
    <h2 class="section-title reveal">La celebración</h2>
    <div class="deco-line reveal" style="transition-delay:0.1s"></div>
    <div class="detalles-grid">
      <div class="det-card reveal" style="transition-delay:0.15s">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
        </div>
        <h3>Fecha</h3>
        <p class="det-main">12 de septiembre</p>
        <p class="det-sec">Sábado · 2026</p>
      </div>
      <div class="det-card det-card-center reveal" style="transition-delay:0.25s">
        <div class="det-photo-small">
          <img src="/foto.jpeg" alt="Aimar y Deborah" />
        </div>
      </div>
      <div class="det-card reveal" style="transition-delay:0.2s">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 3"/>
          </svg>
        </div>
        <h3>Hora</h3>
        <p class="det-main">13:30 h</p>
        <p class="det-sec">de la tarde</p>
      </div>
      <div class="det-card det-lugar reveal" style="transition-delay:0.3s">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M12 21s-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-8 12-8 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
        </div>
        <h3>Lugar</h3>
        <p class="det-main">Palacio de Murguia</p>
        <p class="det-sec">Nagusia Kalea, 15 · Astigarraga, Gipuzkoa</p>
      </div>
    </div>
  </section>

  <!-- MAPA -->
  <section class="mapa" id="mapa">
    <div class="mapa-inner reveal">
      <div class="mapa-text">
        <h2 class="section-title" style="text-align:left;">Cómo llegar</h2>
        <div class="deco-line" style="margin-left:0;"></div>
        <p class="mapa-addr">Nagusia Kalea, 15<br/>20115 Astigarraga<br/>Gipuzkoa</p>
        <a href="https://maps.google.com/?q=Nagusia+Kalea+15,+20115+Astigarraga" target="_blank" rel="noopener noreferrer" class="mapa-btn">
          Abrir en Google Maps →
        </a>
      </div>
      <div class="mapa-embed">
        <iframe
          src="https://maps.google.com/maps?q=Palacio+de+Murguia,+Astigarraga,+Gipuzkoa&t=&z=16&ie=UTF8&iwloc=&output=embed"
          allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          title="Palacio de Murguia"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- RSVP -->
  <section class="rsvp" id="confirmacion">
    <div class="rsvp-photo-bg"></div>
    <div class="rsvp-inner reveal">
      <img src="/logo-negativo.png" alt="A&D" class="rsvp-monogram" />
      <h2 class="rsvp-title">¿Contamos contigo?</h2>
      <p class="rsvp-dead">Confírmanos antes del <strong>10 de agosto</strong></p>

      <!-- Formulario -->
      <form class="rsvp-form" id="rsvpForm" name="rsvp" method="POST" data-netlify="true">
        <div class="rf-field">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo" autocomplete="name" />
        </div>

        <div class="rf-field">
          <span class="rf-label">¿Asistirás?</span>
          <div class="rf-toggle">
            <label class="rf-opt">
              <input type="radio" name="asistencia" value="si" required />
              <span>Sí, allí estaré</span>
            </label>
            <label class="rf-opt">
              <input type="radio" name="asistencia" value="no" />
              <span>No podré ir</span>
            </label>
          </div>
        </div>

        <div class="rf-field" id="rfPersonas" style="display:none">
          <label>¿Cuántos venís?</label>
          <div class="rf-counter">
            <button type="button" class="rf-count-btn" id="rfMinus">−</button>
            <span id="rfCount">1</span>
            <button type="button" class="rf-count-btn" id="rfPlus">+</button>
            <input type="hidden" name="personas" id="rfPersonasInput" value="1" />
          </div>
        </div>

        <div id="rfAsistentes" style="display:none"></div>

        <!-- Campo oculto que Netlify detecta en build time; se rellena con JS antes de enviar -->
        <textarea name="asistentes_detalle" id="asistentesDetalle" style="display:none"></textarea>

        <button type="submit" class="rf-submit">Confirmar</button>
      </form>

      <!-- Estado de éxito -->
      <div class="rsvp-ok" id="rsvpOk" style="display:none">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="9"/><path d="M8 12l3 3 5-5"/></svg>
        <p class="rsvp-ok-title">¡Perfecto!</p>
        <p class="rsvp-ok-sub">Hemos recibido tu confirmación.<br/>Nos vemos el 12 de septiembre.</p>
      </div>
    </div>
  </section>

  <!-- FOTOS -->
  <section class="fotos-preview reveal">
    <div class="fp-inner">
      <p class="fp-eyebrow">Galería</p>
      <h2 class="fp-title">Las fotos del día</h2>
      <div class="fp-deco"></div>
      <p class="fp-text">Después de la boda encontraréis aquí todos los recuerdos del día.<br/>Y podréis subir las vuestras también.</p>
      <a href="/galeria" class="fp-btn">Ver galería →</a>
    </div>
  </section>

  <footer>
    <p>Aimar & Deborah · 12 · 09 · 2026</p>
    <p class="footer-sub">deborahyaimar.com</p>
  </footer>

<script>
  // ── SNAP TO STRAIGHT ON HOVER ─────────────────────────────
  const disc = document.querySelector('.vinyl-record') as HTMLElement;
  const SPIN_MS = 20000;
  let spinStart = Date.now();
  let snapActive = false;

  function currentAngle() {
    return ((Date.now() - spinStart) % SPIN_MS) / SPIN_MS * 360;
  }
  function snapStraight() {
    if (snapActive) return;
    snapActive = true;
    const angle = currentAngle();
    disc.style.animation = 'none';
    disc.style.transform = `rotate(${angle}deg)`;
    void disc.offsetWidth;
    const target = angle <= 180 ? 0 : 360;
    disc.style.transition = 'transform 0.9s cubic-bezier(0.33, 1, 0.68, 1)';
    disc.style.transform = `rotate(${target}deg)`;
  }
  function resumeSpin() {
    if (!snapActive) return;
    snapActive = false;
    disc.style.transition = 'none';
    disc.style.transform = 'rotate(0deg)';
    void disc.offsetWidth;
    disc.style.animation = `spin ${SPIN_MS}ms linear infinite`;
    spinStart = Date.now();
  }
  disc.addEventListener('mouseenter', snapStraight);
  disc.addEventListener('mouseleave', resumeSpin);
  disc.addEventListener('touchstart', snapStraight, { passive: true });
  disc.addEventListener('touchend',   resumeSpin,   { passive: true });

  // ── FUNDA + VINILO: ANIMACIÓN DE SCROLL ──────────────────
  //
  // El vinilo (z:2) está apilado entre la cara posterior (z:1) y la portada (z:3).
  // Mientras el vinilo está DENTRO de la funda, la portada (z:3) lo enmascara
  // naturalmente: sólo la parte que sobresale por arriba de la portada es visible.
  // Cuando la funda llega casi a 0% de opacidad, se hace el cambio de z-index
  // (z:2→5) sin que se note, y el disco queda girando libre.

  const stickyContainer = document.querySelector('.vinyl-sticky-container') as HTMLElement;
  const sceneBg         = document.querySelector('.vinyl-scene-bg')         as HTMLElement;
  const sleeveFront     = document.querySelector('#sleeveFront')            as HTMLElement;
  const sleeveBack      = document.querySelector('#sleeveBack')             as HTMLElement;
  const vinylRiser      = document.querySelector('#vinylRiser')             as HTMLElement;

  // easing cuadrático suave
  function ease(t: number) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }
  // normaliza progress entre [a, b] → [0, 1]
  function seg(p: number, a: number, b: number) {
    return Math.max(0, Math.min(1, (p - a) / (b - a)));
  }

  // Posición vertical del vinilo en vh (positivo = abajo, negativo = arriba)
  // Empieza en 0 (centrado, oculto detrás de la portada) y sube hasta -20vh
  function vinylVh(p: number): number {
    if (p < 0.65) return -9 + (-11) * ease(seg(p, 0.00, 0.65)); // sube: -9 → -20vh
    return -20 + 20 * ease(seg(p, 0.65, 0.92));                 // se asienta: -20 → 0
  }

  let vinylFront = false;

  function updateScene() {
    const rect      = stickyContainer.getBoundingClientRect();
    const maxScroll = stickyContainer.offsetHeight - window.innerHeight;
    const p         = Math.max(0, Math.min(1, -rect.top / maxScroll));

    // ① VINILO SUBE Y SE ASIENTA
    const vy = vinylVh(p);
    vinylRiser.style.transform = `translate(-50%, calc(-50% + ${vy}vh))`;

    // ② OPACIDAD DEL VINILO: aparece mientras emerge (0.05 → 0.45)
    vinylRiser.style.opacity = String(ease(seg(p, 0.05, 0.45)));

    // ③ CAMBIO DE Z-INDEX: cuando la funda es ya casi invisible (p > 0.72)
    if (p > 0.72 && !vinylFront) {
      vinylFront = true;
      vinylRiser.style.zIndex = '5';
    } else if (p <= 0.72 && vinylFront) {
      vinylFront = false;
      vinylRiser.style.zIndex = '2';
    }

    // ④ FUNDA SE DESVANECE Y BAJA (0.18 → 0.72)
    const sleeveP  = ease(seg(p, 0.18, 0.72));
    const sleeveOp = 1 - sleeveP;
    const sleeveY  = `translateY(${8 * sleeveP}%)`;
    sleeveFront.style.opacity   = String(sleeveOp);
    sleeveFront.style.transform = sleeveY;
    sleeveBack.style.opacity    = String(sleeveOp);
    sleeveBack.style.transform  = sleeveY;

    // ⑤ FONDO OSCURO DESAPARECE (0.62 → 0.92)
    sceneBg.style.opacity = String(1 - ease(seg(p, 0.62, 0.92)));
  }

  window.addEventListener('scroll', updateScene, { passive: true });
  updateScene();

  // ── RSVP FORM ────────────────────────────────────────────
  const form           = document.getElementById('rsvpForm')       as HTMLFormElement;
  const rfPersonas     = document.getElementById('rfPersonas')     as HTMLElement;
  const rfAsistentes   = document.getElementById('rfAsistentes')   as HTMLElement;
  const rfMinus        = document.getElementById('rfMinus')        as HTMLButtonElement;
  const rfPlus         = document.getElementById('rfPlus')         as HTMLButtonElement;
  const rfCount        = document.getElementById('rfCount')        as HTMLElement;
  const rfInput        = document.getElementById('rfPersonasInput') as HTMLInputElement;
  const rsvpOk         = document.getElementById('rsvpOk')         as HTMLElement;
  const nombreInput    = document.getElementById('nombre')         as HTMLInputElement;
  let personas = 1;

  function renderAttendees() {
    rfAsistentes.innerHTML = '';
    for (let i = 1; i <= personas; i++) {
      const row = document.createElement('div');
      row.className = 'rf-attendee';
      const prefill = i === 1 ? (nombreInput.value || '') : '';
      row.innerHTML = `
        <p class="rf-attendee-label">Asistente ${i}</p>
        <div class="rf-attendee-fields">
          <input type="text" name="asistente_${i}_nombre" placeholder="Nombre" value="${prefill.replace(/"/g,'&quot;')}" />
          <input type="text" name="asistente_${i}_alergias" placeholder="Alergias (o vacío si ninguna)" />
        </div>`;
      rfAsistentes.appendChild(row);
    }
  }

  form.querySelectorAll('input[name="asistencia"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const val = (form.querySelector('input[name="asistencia"]:checked') as HTMLInputElement)?.value;
      const asiste = val === 'si';
      rfPersonas.style.display = asiste ? 'flex' : 'none';
      rfAsistentes.style.display = asiste ? 'flex' : 'none';
      if (asiste) renderAttendees();
    });
  });

  rfMinus.addEventListener('click', () => {
    if (personas > 1) { personas--; rfCount.textContent = String(personas); rfInput.value = String(personas); renderAttendees(); }
  });
  rfPlus.addEventListener('click', () => {
    if (personas < 20) { personas++; rfCount.textContent = String(personas); rfInput.value = String(personas); renderAttendees(); }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Serializar asistentes en el campo oculto que Netlify sí detecta
    const detalleEl = document.getElementById('asistentesDetalle') as HTMLTextAreaElement;
    if (personas > 0 && rfAsistentes.style.display !== 'none') {
      const lines: string[] = [];
      for (let i = 1; i <= personas; i++) {
        const n = (form.querySelector(`[name="asistente_${i}_nombre"]`) as HTMLInputElement)?.value || '';
        const a = (form.querySelector(`[name="asistente_${i}_alergias"]`) as HTMLInputElement)?.value || '';
        lines.push(`${i}. ${n}${a ? ' — ' + a : ''}`);
      }
      detalleEl.value = lines.join('\n');
    }

    const btn = form.querySelector('.rf-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando…';
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as any).toString(),
      });
      if (res.ok) {
        form.style.display = 'none';
        rsvpOk.style.display = 'flex';
      } else {
        btn.disabled = false;
        btn.textContent = 'Confirmar';
        alert('Hubo un problema. Inténtalo de nuevo.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Confirmar';
      alert('Sin conexión. Inténtalo de nuevo.');
    }
  });

  // ── FADE-IN DE SECCIONES ──────────────────────────────────
  const fadeEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  fadeEls.forEach(el => io.observe(el));
</script>

</body>
</html>

<style is:global>
  @font-face {
    font-family: 'Sloop';
    src: url('/fonts/Sloop-ScriptThree.ttf') format('truetype');
    font-weight: normal;
    font-display: swap;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAF8F4;
    --blush: #F5E5ED;
    --rose: #E8C5D2;
    --rosewood: #7A3B50;
    --pink: #F2B3CE;
    --pink-label: #F4BCCE;
    --dark: #1a1a1a;
    --gray: #8a7070;
    --border: #e6d8dc;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--dark);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.65;
    letter-spacing: 0.03em;
    -webkit-font-smoothing: antialiased;
  }

  /* ── VERSION NAV ──────────────────────────────────────── */
  .vn {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(250,248,244,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    font-size: 0.7rem; letter-spacing: 0.12em;
  }
  .vn-back { color: var(--gray); text-decoration: none; transition: color 0.2s; }
  .vn-back:hover { color: var(--dark); }
  .vn-pills { display: flex; gap: 0.4rem; }
  .vn-pill {
    text-decoration: none; padding: 0.3rem 0.8rem;
    border-radius: 100px; border: 1px solid var(--border);
    color: var(--gray); font-size: 0.68rem; letter-spacing: 0.1em;
    transition: all 0.2s;
  }
  .vn-pill:hover { border-color: var(--pink); color: var(--dark); }
  .vn-active { background: var(--rosewood); border-color: var(--rosewood); color: #fff !important; }

  /* ── NAV ──────────────────────────────────────────────── */
  nav {
    position: fixed; top: 42px; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: center; padding: 1rem;
    mix-blend-mode: multiply;
  }
  .nav-logo { width: 36px; opacity: 0.7; }

  /* ── HERO ─────────────────────────────────────────────── */
  .hero {
    position: relative; height: 100svh; min-height: 600px;
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .hero-image-wrap { position: absolute; inset: 0; }
  .hero-img {
    width: 100%; height: 100%; object-fit: cover; object-position: center 30%;
    filter: grayscale(10%) brightness(0.68);
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(26,10,14,0.1) 0%, rgba(26,10,14,0.25) 50%, rgba(26,10,14,0.6) 100%);
  }
  .hero-content { position: relative; z-index: 2; text-align: center; color: #fff; padding: 2rem; }
  .hero-pre { font-size: 0.75rem; letter-spacing: 0.3em; text-transform: uppercase; font-weight: 200; margin-bottom: 1.25rem; opacity: 0.8; }
  .hero-names {
    font-family: 'Sloop', cursive;
    font-size: clamp(4rem, 13vw, 9.5rem);
    font-weight: normal; line-height: 1; margin-bottom: 1.5rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.2);
  }
  .hero-names .amp { font-size: 0.7em; opacity: 0.8; margin: 0 0.05em; }
  .hero-date { font-size: 0.9rem; letter-spacing: 0.35em; font-weight: 200; margin-bottom: 0.5rem; }
  .hero-venue { font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.7; font-weight: 200; }
  .hero-scroll { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); z-index: 2; }
  .scroll-line {
    display: block; width: 1px; height: 55px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.5));
    animation: scrollFade 2s ease-in-out infinite;
  }
  @keyframes scrollFade {
    0%, 100% { opacity: 0; transform: scaleY(0.1) translateY(-10px); }
    60%       { opacity: 1; transform: scaleY(1)   translateY(0);     }
  }

  /* ═══════════════════════════════════════════════════════
     FUNDA + VINILO
  ═══════════════════════════════════════════════════════ */

  .vinyl-sticky-container {
    height: 210vh;
    position: relative;
  }

  .invitacion {
    position: sticky;
    top: 42px;
    height: calc(100vh - 42px);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  /* Fondo oscuro (desaparece al final) */
  .vinyl-scene-bg {
    position: absolute; inset: 0;
    background: var(--dark);
    pointer-events: none;
    z-index: 0;
    will-change: opacity;
  }

  /* ── FUNDA (sleeve-scene) ─────────────────────────────── */
  /*
    Tamaño: cuadrado, igual que el sobre.pdf.
    Ligeramente más grande que el vinilo para contenerlo.
  */
  .sleeve-scene {
    position: relative;
    width:  clamp(320px, 95vw, 620px);
    height: clamp(320px, 95vw, 620px);
    flex-shrink: 0;
  }
  @media (min-width: 600px) {
    .sleeve-scene {
      width: clamp(320px, 76vw, 620px);
      height: clamp(320px, 76vw, 620px);
    }
  }

  /* Cara posterior: simple, oscura, da profundidad */
  .sleeve-back {
    position: absolute; inset: 0;
    background: #1C1613;
    border-radius: 4px;
    box-shadow:
      0 40px 120px rgba(0,0,0,0.7),
      0 0 0 1px rgba(255,255,255,0.06);
    z-index: 1;
    will-change: transform, opacity;
  }

  /* ── PORTADA (sleeve-front) ───────────────────────────── */
  /*
    Diseño replicando el sobre.pdf:
    - Lado derecho (~67%): foto de la pareja
    - Lado izquierdo: espacio blanco con datos
    - Esquina sup. derecha: nombres en script
    - Esquina inf. izquierda: fecha y lugar
    - Esquina inf. derecha: monograma
  */
  .sleeve-front {
    position: absolute; inset: 0;
    background: #FAFAF8;
    border-radius: 4px;
    overflow: hidden;
    z-index: 3;
    box-shadow:
      0 40px 120px rgba(0,0,0,0.7),
      0 0 0 1px rgba(0,0,0,0.07);
    will-change: transform, opacity;
  }

  /* Foto (lado derecho, cubre ~67% de ancho, toda la altura) */
  .sf-photo {
    position: absolute;
    top: 0; right: 0;
    width: 67%; height: 100%;
  }
  .sf-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 22%;
    display: block;
  }

  /*
    Sombra interior en el borde superior:
    sugiere la ranura abierta de la funda por donde sale el vinilo.
  */
  .sf-top-shadow {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 28px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.18), transparent);
    z-index: 2;
    pointer-events: none;
  }

  /* Nombres en script (esquina sup. derecha, sobre la foto) */
  .sf-script {
    position: absolute;
    top: 7%; right: 5%;
    font-family: 'Sloop', cursive;
    font-size: clamp(1.55rem, 4vw, 2.75rem);
    color: #fff;
    text-shadow: 0 2px 18px rgba(0,0,0,0.38);
    line-height: 1;
    z-index: 2;
    text-align: right;
  }
  .sf-amp { font-size: 0.76em; opacity: 0.85; margin: 0 0.05em; }

  /* Datos de la boda (esquina inf. izquierda, en espacio blanco) */
  .sf-info {
    position: absolute;
    bottom: 7%; left: 5%;
    z-index: 2;
  }
  .sf-date {
    font-size: clamp(0.88rem, 2.3vw, 1.18rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--dark);
    margin-bottom: 0.3rem;
    line-height: 1.2;
  }
  .sf-venue {
    font-size: clamp(0.55rem, 1.4vw, 0.72rem);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 300;
  }

  /* Monograma (esquina inf. derecha, encima de la foto) */
  .sf-mono {
    position: absolute;
    bottom: 5%; right: 5%;
    width: clamp(26px, 4.2vw, 38px);
    opacity: 0.55;
    z-index: 2;
    /* el logo positivo es negro → invertir para que sea blanco sobre la foto */
    filter: invert(1) brightness(2);
  }

  /* ── VINILO ───────────────────────────────────────────── */
  /*
    Centrado dentro de sleeve-scene.
    El JS actualiza el transform completo (incluye el offset de scroll).
    Empieza a 52vh debajo del centro → overflow:hidden lo mantiene invisible
    hasta que entra en el viewport y empieza a asomar por encima de la portada.
  */
  .vinyl-riser {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, calc(-50% - 9vh));
    opacity: 0.35;
    z-index: 2;
    will-change: transform, opacity;
  }

  .vinyl-record {
