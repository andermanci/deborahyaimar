---
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/logo-positivo.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Aimar & Deborah — 12 · 09 · 2026 · Palacio de Murguia, Astigarraga" />
  <title>Aimar & Deborah · Clásica Elegante</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,200;0,300;0,400;0,500;1,200;1,300&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- VERSION NAV -->
  <div class="vn">
    <a href="/" class="vn-back">← propuestas</a>
    <div class="vn-pills">
      <a href="/v1" class="vn-pill vn-active">01 Clásica</a>
      <a href="/v2" class="vn-pill">02 Oscura</a>
      <a href="/v3" class="vn-pill">03 Romántica</a>
    </div>
  </div>

  <!-- NAV -->
  <nav>
    <img src="/logo-positivo.png" alt="A&D monogram" class="nav-logo" />
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-image-wrap">
      <img src="/foto.jpg" alt="Aimar y Deborah" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <p class="hero-pre">os invitamos a nuestra boda</p>
      <h1 class="hero-names">Aimar <span class="amp">&</span> Deborah</h1>
      <p class="hero-date">12 · 09 · 2026</p>
      <p class="hero-venue">Palacio de Murguia, Astigarraga</p>
    </div>
    <div class="hero-scroll"><span class="scroll-line"></span></div>
  </section>

  <!-- VINYL -->
  <section class="invitacion" id="invitacion">
    <div class="vinyl-wrap">
      <div class="vinyl-record">
        <div class="vinyl-grooves"></div>
        <div class="vinyl-label">
          <div class="vinyl-label-inner">
            <p>Dicen que las mejores canciones nacen de mezclas inesperadas. Dos estilos distintos, dos formas de ser y una canción que encaja a la perfección.</p>
            <p>Después de un tiempo sonando juntos, hemos decidido que esta canción dure para siempre.</p>
            <p class="vinyl-cta">Dale al play con nosotros el</p>
            <p class="vinyl-date-small">12 · 09 · 2026</p>
            <div class="vinyl-hole"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DETALLES -->
  <section class="detalles" id="detalles">
    <div class="section-header">
      <h2 class="section-title">La celebración</h2>
      <div class="divider"></div>
    </div>
    <div class="detalles-grid">
      <div class="detalle-item">
        <span class="detalle-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        </span>
        <h3>Fecha</h3>
        <p>Sábado</p>
        <p class="detalle-main">12 de septiembre de 2026</p>
      </div>
      <div class="detalle-item">
        <span class="detalle-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        </span>
        <h3>Hora</h3>
        <p>A las</p>
        <p class="detalle-main">13:00 h</p>
      </div>
      <div class="detalle-item">
        <span class="detalle-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-8 12-8 12z"/><circle cx="12" cy="9" r="2.5"/></svg>
        </span>
        <h3>Lugar</h3>
        <p>Palacio de Murguia</p>
        <p class="detalle-main">Astigarraga</p>
      </div>
    </div>
  </section>

  <!-- MAPA -->
  <section class="mapa" id="mapa">
    <div class="section-header">
      <h2 class="section-title">Cómo llegar</h2>
      <div class="divider"></div>
    </div>
    <p class="mapa-address">Nagusia Kalea, 15 · 20115 Astigarraga, Gipuzkoa</p>
    <div class="mapa-container">
      <iframe
        src="https://maps.google.com/maps?q=Palacio+de+Murguia,+Astigarraga,+Gipuzkoa&t=&z=16&ie=UTF8&iwloc=&output=embed"
        allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        title="Palacio de Murguia, Astigarraga"
      ></iframe>
    </div>
    <a href="https://maps.google.com/?q=Nagusia+Kalea+15,+20115+Astigarraga" target="_blank" rel="noopener noreferrer" class="mapa-btn">
      Abrir en Google Maps
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </section>

  <!-- RSVP -->
  <section class="rsvp" id="confirmacion">
    <div class="rsvp-inner">
      <img src="/logo-negativo.png" alt="A&D" class="rsvp-logo" />
      <h2 class="rsvp-title">¿Contamos contigo?</h2>
      <p class="rsvp-sub">Confírmanos antes del <strong>10 de agosto</strong></p>

      <!-- Formulario -->
      <form class="rsvp-form" id="rsvpForm" name="rsvp" method="POST" data-netlify="true">
        <div class="rf-field">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo" autocomplete="name" />
        </div>

        <div class="rf-field">
          <span class="rf-label">¿Asistirás?</span>
          <div class="rf-toggle">
            <label class="rf-opt">
              <input type="radio" name="asistencia" value="si" required />
              <span>Sí, allí estaré</span>
            </label>
            <label class="rf-opt">
              <input type="radio" name="asistencia" value="no" />
              <span>No podré ir</span>
            </label>
          </div>
        </div>

        <div class="rf-field" id="rfPersonas" style="display:none">
          <label>¿Cuántos venís?</label>
          <div class="rf-counter">
            <button type="button" class="rf-count-btn" id="rfMinus">−</button>
            <span id="rfCount">1</span>
            <button type="button" class="rf-count-btn" id="rfPlus">+</button>
            <input type="hidden" name="personas" id="rfPersonasInput" value="1" />
          </div>
        </div>

        <div id="rfAsistentes" style="display:none"></div>

        <!-- Campo oculto que Netlify detecta en build time; se rellena con JS antes de enviar -->
        <textarea name="asistentes_detalle" id="asistentesDetalle" style="display:none"></textarea>

        <button type="submit" class="rf-submit">Confirmar</button>
      </form>

      <!-- Estado de éxito -->
      <div class="rsvp-ok" id="rsvpOk" style="display:none">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="9"/><path d="M8 12l3 3 5-5"/></svg>
        <p class="rsvp-ok-title">¡Perfecto!</p>
        <p class="rsvp-ok-sub">Hemos recibido tu confirmación.<br/>Nos vemos el 12 de septiembre.</p>
      </div>
    </div>
  </section>

  <!-- FOTOS -->
  <section class="fotos-preview reveal">
    <div class="fp-inner">
      <p class="fp-eyebrow">Galería</p>
      <h2 class="fp-title">Las fotos del día</h2>
      <div class="fp-deco"></div>
      <p class="fp-text">Después de la boda encontraréis aquí todos los recuerdos del día.<br/>Y podréis subir las vuestras también.</p>
      <a href="/galeria" class="fp-btn">Ver galería →</a>
    </div>
  </section>

  <footer>
    <p>Aimar & Deborah · 12 · 09 · 2026</p>
    <p class="footer-sub">deborahyaimar.com</p>
  </footer>

<script>
  // ── RSVP FORM ─────────────────────────────────────────────────
  const form           = document.getElementById('rsvpForm')       as HTMLFormElement;
  const rfPersonas     = document.getElementById('rfPersonas')     as HTMLElement;
  const rfAsistentes   = document.getElementById('rfAsistentes')   as HTMLElement;
  const rfMinus        = document.getElementById('rfMinus')        as HTMLButtonElement;
  const rfPlus         = document.getElementById('rfPlus')         as HTMLButtonElement;
  const rfCount        = document.getElementById('rfCount')        as HTMLElement;
  const rfInput        = document.getElementById('rfPersonasInput') as HTMLInputElement;
  const rsvpOk         = document.getElementById('rsvpOk')        as HTMLElement;
  const nombreInput    = document.getElementById('nombre')         as HTMLInputElement;
  let personas = 1;

  function renderAttendees() {
    rfAsistentes.innerHTML = '';
    for (let i = 1; i <= personas; i++) {
      const row = document.createElement('div');
      row.className = 'rf-attendee';
      const prefill = i === 1 ? (nombreInput.value || '') : '';
      row.innerHTML = `
        <p class="rf-attendee-label">Asistente ${i}</p>
        <div class="rf-field rf-attendee-fields">
          <input type="text" name="asistente_${i}_nombre" placeholder="Nombre" value="${prefill.replace(/"/g,'&quot;')}" />
          <input type="text" name="asistente_${i}_alergias" placeholder="Alergias (o vacío si ninguna)" />
        </div>`;
      rfAsistentes.appendChild(row);
    }
  }

  // Mostrar / ocultar campos según asistencia
  form.querySelectorAll('input[name="asistencia"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const val = (form.querySelector('input[name="asistencia"]:checked') as HTMLInputElement)?.value;
      const asiste = val === 'si';
      rfPersonas.style.display = asiste ? 'flex' : 'none';
      rfAsistentes.style.display = asiste ? 'flex' : 'none';
      if (asiste) renderAttendees();
    });
  });

  // Counter +/-
  rfMinus.addEventListener('click', () => {
    if (personas > 1) { personas--; rfCount.textContent = String(personas); rfInput.value = String(personas); renderAttendees(); }
  });
  rfPlus.addEventListener('click', () => {
    if (personas < 20) { personas++; rfCount.textContent = String(personas); rfInput.value = String(personas); renderAttendees(); }
  });

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Serializar asistentes en el campo oculto que Netlify sí detecta
    const detalleEl = document.getElementById('asistentesDetalle') as HTMLTextAreaElement;
    if (personas > 0 && rfAsistentes.style.display !== 'none') {
      const lines: string[] = [];
      for (let i = 1; i <= personas; i++) {
        const n = (form.querySelector(`[name="asistente_${i}_nombre"]`) as HTMLInputElement)?.value || '';
        const a = (form.querySelector(`[name="asistente_${i}_alergias"]`) as HTMLInputElement)?.value || '';
        lines.push(`${i}. ${n}${a ? ' — ' + a : ''}`);
      }
      detalleEl.value = lines.join('\n');
    }

    const btn = form.querySelector('.rf-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando…';
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as any).toString(),
      });
      if (res.ok) {
        form.style.display = 'none';
        rsvpOk.style.display = 'flex';
      } else {
        btn.disabled = false;
        btn.textContent = 'Confirmar';
        alert('Hubo un problema. Inténtalo de nuevo.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Confirmar';
      alert('Sin conexión. Inténtalo de nuevo.');
    }
  });

  // ── VINILO ────────────────────────────────────────────────────
  const disc = document.querySelector('.vinyl-record') as HTMLElement;
  const SPIN_MS = 20000;
  let spinStart = Date.now();
  let active = false;

  function currentAngle() {
    return ((Date.now() - spinStart) % SPIN_MS) / SPIN_MS * 360;
  }

  function snapStraight() {
    if (active) return;
    active = true;

    const angle = currentAngle();
    // Detiene la animación CSS y fija el ángulo actual
    disc.style.animation = 'none';
    disc.style.transform = `rotate(${angle}deg)`;

    // Fuerza reflow para que el navegador registre el estado antes de la transición
    void disc.offsetWidth;

    // Rota al 0° más cercano por el camino más corto
    const target = angle <= 180 ? 0 : 360;
    disc.style.transition = 'transform 0.9s cubic-bezier(0.33, 1, 0.68, 1)';
    disc.style.transform = `rotate(${target}deg)`;
  }

  function resumeSpin() {
    if (!active) return;
    active = false;

    disc.style.transition = 'none';
    disc.style.transform = 'rotate(0deg)';
    void disc.offsetWidth;

    disc.style.animation = `spin ${SPIN_MS}ms linear infinite`;
    spinStart = Date.now();
  }

  disc.addEventListener('mouseenter', snapStraight);
  disc.addEventListener('mouseleave', resumeSpin);
  disc.addEventListener('touchstart', snapStraight, { passive: true });
  disc.addEventListener('touchend',   resumeSpin,   { passive: true });
</script>

</body>
</html>

<style is:global>
  @font-face {
    font-family: 'Sloop';
    src: url('/fonts/Sloop-ScriptThree.ttf') format('truetype');
    font-weight: normal;
    font-display: swap;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAFAF7;
    --black: #111111;
    --pink: #F2B3CE;
    --pink-deep: #C8829E;
    --pink-label: #F4BCCE;
    --gray: #888;
    --gray-light: #e8e8e5;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--black);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: 0.03em;
    -webkit-font-smoothing: antialiased;
  }

  /* VERSION NAV */
  .vn {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(250,250,247,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--gray-light);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }

  .vn-back {
    color: var(--gray);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s;
  }
  .vn-back:hover { color: var(--black); }

  .vn-pills {
    display: flex;
    gap: 0.4rem;
  }

  .vn-pill {
    text-decoration: none;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    border: 1px solid var(--gray-light);
    color: var(--gray);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    transition: all 0.2s;
  }

  .vn-pill:hover { border-color: var(--pink); color: var(--black); }

  .vn-active {
    background: var(--black);
    border-color: var(--black);
    color: #fff !important;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 42px; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 1rem;
    mix-blend-mode: multiply;
  }

  .nav-logo { width: 36px; opacity: 0.7; }

  /* HERO */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image-wrap { position: absolute; inset: 0; }

  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 30%;
    filter: grayscale(15%) brightness(0.72);
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(10,10,10,0.1) 0%, rgba(10,10,10,0.2) 50%, rgba(10,10,10,0.55) 100%);
  }

  .hero-content {
    position: relative; z-index: 2;
    text-align: center; color: #fff; padding: 2rem;
  }

  .hero-pre {
    font-size: 0.75rem; letter-spacing: 0.3em;
    text-transform: uppercase; font-weight: 200;
    margin-bottom: 1.25rem; opacity: 0.8;
  }

  .hero-names {
    font-family: 'Sloop', cursive;
    font-size: clamp(4rem, 13vw, 9.5rem);
    font-weight: normal; line-height: 1;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.25);
  }

  .hero-names .amp { font-size: 0.7em; opacity: 0.8; margin: 0 0.05em; }

  .hero-date {
    font-size: 0.9rem; letter-spacing: 0.35em;
    font-weight: 200; margin-bottom: 0.5rem;
  }

  .hero-venue {
    font-size: 0.75rem; letter-spacing: 0.18em;
    text-transform: uppercase; opacity: 0.7; font-weight: 200;
  }

  .hero-scroll {
    position: absolute; bottom: 2.5rem;
    left: 50%; transform: translateX(-50%); z-index: 2;
  }

  .scroll-line {
    display: block; width: 1px; height: 55px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.55));
    animation: scrollFade 2s ease-in-out infinite;
  }

  @keyframes scrollFade {
    0%, 100% { opacity: 0; transform: scaleY(0.1) translateY(-10px); }
    60% { opacity: 1; transform: scaleY(1) translateY(0); }
  }

  /* SECTIONS */
  section { padding: 5rem 1.5rem; }

  .section-header { text-align: center; margin-bottom: 3.5rem; }

  .section-title {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 200;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .divider {
    width: 50px; height: 1px;
    background: var(--pink-deep); margin: 0 auto;
  }

  /* VINYL */
  .invitacion {
    background: var(--black);
    display: flex; justify-content: center; align-items: center;
  }

  .vinyl-record {
    position: relative;
    width: clamp(300px, 72vw, 580px);
    aspect-ratio: 1; border-radius: 50%;
    background: radial-gradient(circle at 48% 48%, #2a2a2a, #111 40%, #080808 70%);
    box-shadow: 0 0 0 2px #2a2a2a, inset 0 0 50px rgba(0,0,0,0.9), 0 24px 80px rgba(0,0,0,0.7);
    animation: spin 20s linear infinite;
    cursor: pointer;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .vinyl-grooves {
    position: absolute; inset: 7%; border-radius: 50%;
    background: repeating-radial-gradient(
      circle at center,
      transparent 0px, transparent 5px,
      rgba(255,255,255,0.025) 5px, rgba(255,255,255,0.025) 6px
    );
  }

  .vinyl-label {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 50%; aspect-ratio: 1; border-radius: 50%;
    background: var(--pink-label);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }

  .vinyl-label::before {
    content: '';
    position: absolute; inset: 0;
    background: url('/logo-negativo.png') center / 55% no-repeat;
    opacity: 0.15;
  }

  .vinyl-label-inner {
    position: relative; text-align: center;
    /* Usar width en vez de padding: un círculo tiene menos altura
       útil cuanto más ancho es el contenido. 62% es el equilibrio. */
    width: 80%;
    font-size: clamp(0.58rem, 1.45vw, 0.82rem);
    color: #111; line-height: 1.45;
    padding-top: 1.5rem;
  }

  .vinyl-label-inner p { margin-bottom: 0.3em; }
  .vinyl-cta { margin-top: 0.5em !important; font-style: italic; opacity: 0.75; }
  .vinyl-date-small { font-weight: 600 !important; letter-spacing: 0.1em; font-size: 1.1em; }

  @media (max-width: 500px) {
    .vinyl-label {
      width: 64%;
    }
    .vinyl-label-inner {
      width: 82%;
      padding-top: 0;
      font-size: 0.6rem;
      line-height: 1.35;
    }
    .vinyl-label-inner p { margin-bottom: 0.2em; }
    .vinyl-cta { margin-top: 0.35em !important; }
  }

  .vinyl-hole {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 8px; height: 8px;
    background: #111; border-radius: 50%;
  }

  /* DETALLES */
  .detalles { background: var(--cream); max-width: 1000px; margin: 0 auto; }

  .detalles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem; max-width: 750px; margin: 0 auto;
  }

  .detalle-item {
    text-align: center; padding: 2.5rem 1.5rem;
    border: 1px solid var(--gray-light); border-radius: 2px;
    transition: border-color 0.3s;
  }

  .detalle-item:hover { border-color: var(--pink); }

  .detalle-icon { display: flex; justify-content: center; margin-bottom: 1.25rem; }
  .detalle-icon svg { width: 26px; height: 26px; color: var(--pink-deep); }

  .detalle-item h3 {
    font-size: 0.65rem; letter-spacing: 0.22em;
    text-transform: uppercase; font-weight: 500;
    color: var(--gray); margin-bottom: 0.5rem;
  }

  .detalle-item p { font-size: 0.85rem; color: var(--gray); font-weight: 300; }

  .detalle-main {
    font-size: clamp(1rem, 2.5vw, 1.3rem) !important;
    color: var(--black) !important;
    font-weight: 300 !important;
    letter-spacing: 0.04em;
    line-height: 1.3; margin-top: 0.25rem;
  }

  /* MAPA */
  .mapa { background: #f0ede8; text-align: center; }

  .mapa-address {
    font-size: 0.8rem; letter-spacing: 0.12em;
    color: var(--gray); margin-bottom: 2.5rem; font-weight: 300;
  }

  .mapa-container {
    max-width: 880px; margin: 0 auto 2rem;
    border-radius: 2px; overflow: hidden;
    box-shadow: 0 4px 30px rgba(0,0,0,0.07); aspect-ratio: 16/9;
  }

  .mapa-container iframe { width: 100%; height: 100%; border: 0; display: block; }

  .mapa-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--black); text-decoration: none;
    border-bottom: 1px solid var(--black); padding-bottom: 2px;
