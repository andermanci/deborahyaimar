        <a href="tel:+34634421876" class="rsvp-contact">
          <span class="rsvp-name">Aimar</span>
          <span class="rsvp-phone">634 421 876</span>
        </a>
        <div class="rsvp-divider-v"></div>
        <a href="tel:+34644455703" class="rsvp-contact">
