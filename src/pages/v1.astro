  <footer>
    <p>Aimar & Deborah · 12 · 09 · 2026</p>
    <p class="footer-sub">deborahyaimar.com</p>
  </footer>

<script>
  const disc = document.querySelector('.vinyl-record') as HTMLElement;
  const SPIN_MS = 20000;
  let spinStart = Date.now();
  let active = false;

  function currentAngle() {
    return ((Date.now() - spinStart) % SPIN_MS) / SPIN_MS * 360;
  }

  function snapStraight() {
    if (active) return;
    active = true;

    const angle = currentAngle();
    // Detiene la animación CSS y fija el ángulo actual
    disc.style.animation = 'none';
    disc.style.transform = `rotate(${angle}deg)`;

    // Fuerza reflow para que el navegador registre el estado antes de la transición
    void disc.offsetWidth;

    // Rota al 0° más cercano por el camino más corto
    const target = angle <= 180 ? 0 : 360;
    disc.style.transition = 'transform 0.9s cubic-bezier(0.33, 1, 0.68, 1)';
    disc.style.transform = `rotate(${target}deg)`;
  }

  function resumeSpin() {
    if (!active) return;
    active = false;

    disc.style.transition = 'none';
    disc.style.transform = 'rotate(0deg)';
    void disc.offsetWidth;

    disc.style.animation = `spin ${SPIN_MS}ms linear infinite`;
    spinStart = Date.now();
  }

  disc.addEventListener('mouseenter', snapStraight);
  disc.addEventListener('mouseleave', resumeSpin);
  disc.addEventListener('touchstart', snapStraight, { passive: true });
  disc.addEventListener('touchend',   resumeSpin,   { passive: true });
</script>

</body>
</html>

<style is:global>
  @font-face {
    font-family: 'Sloop';
    src: url('/fonts/Sloop-ScriptThree.ttf') format('truetype');
    font-weight: normal;
    font-display: swap;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAFAF7;
    --black: #111111;
    --pink: #F2B3CE;
    --pink-deep: #C8829E;
    --pink-label: #F4BCCE;
    --gray: #888;
    --gray-light: #e8e8e5;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--black);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: 0.03em;
    -webkit-font-smoothing: antialiased;
  }

  /* VERSION NAV */
  .vn {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(250,250,247,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--gray-light);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }

  .vn-back {
    color: var(--gray);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s;
  }
  .vn-back:hover { color: var(--black); }

  .vn-pills {
    display: flex;
    gap: 0.4rem;
  }

  .vn-pill {
    text-decoration: none;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    border: 1px solid var(--gray-light);
    color: var(--gray);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    transition: all 0.2s;
  }

  .vn-pill:hover { border-color: var(--pink); color: var(--black); }

  .vn-active {
    background: var(--black);
    border-color: var(--black);
    color: #fff !important;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 42px; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 1rem;
    mix-blend-mode: multiply;
  }

  .nav-logo { width: 36px; opacity: 0.7; }

  /* HERO */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image-wrap { position: absolute; inset: 0; }

  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 30%;
    filter: grayscale(15%) brightness(0.72);
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(10,10,10,0.1) 0%, rgba(10,10,10,0.2) 50%, rgba(10,10,10,0.55) 100%);
  }

  .hero-content {
    position: relative; z-index: 2;
    text-align: center; color: #fff; padding: 2rem;
  }

  .hero-pre {
    font-size: 0.75rem; letter-spacing: 0.3em;
    text-transform: uppercase; font-weight: 200;
    margin-bottom: 1.25rem; opacity: 0.8;
  }

  .hero-names {
    font-family: 'Sloop', cursive;
    font-size: clamp(4rem, 13vw, 9.5rem);
    font-weight: normal; line-height: 1;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.25);
  }

  .hero-names .amp { font-size: 0.7em; opacity: 0.8; margin: 0 0.05em; }

  .hero-date {
    font-size: 0.9rem; letter-spacing: 0.35em;
    font-weight: 200; margin-bottom: 0.5rem;
  }

  .hero-venue {
    font-size: 0.75rem; letter-spacing: 0.18em;
    text-transform: uppercase; opacity: 0.7; font-weight: 200;
  }

  .hero-scroll {
    position: absolute; bottom: 2.5rem;
    left: 50%; transform: translateX(-50%); z-index: 2;
  }

  .scroll-line {
    display: block; width: 1px; height: 55px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.55));
    animation: scrollFade 2s ease-in-out infinite;
  }

  @keyframes scrollFade {
    0%, 100% { opacity: 0; transform: scaleY(0.1) translateY(-10px); }
    60% { opacity: 1; transform: scaleY(1) translateY(0); }
  }

  /* SECTIONS */
  section { padding: 5rem 1.5rem; }

  .section-header { text-align: center; margin-bottom: 3.5rem; }

  .section-title {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 200;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .divider {
    width: 50px; height: 1px;
    background: var(--pink-deep); margin: 0 auto;
  }

  /* VINYL */
  .invitacion {
    background: var(--black);
    display: flex; justify-content: center; align-items: center;
  }

  .vinyl-record {
    position: relative;
    width: clamp(300px, 72vw, 580px);
    aspect-ratio: 1; border-radius: 50%;
    background: radial-gradient(circle at 48% 48%, #2a2a2a, #111 40%, #080808 70%);
    box-shadow: 0 0 0 2px #2a2a2a, inset 0 0 50px rgba(0,0,0,0.9), 0 24px 80px rgba(0,0,0,0.7);
    animation: spin 20s linear infinite;
    cursor: pointer;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .vinyl-grooves {
    position: absolute; inset: 7%; border-radius: 50%;
    background: repeating-radial-gradient(
      circle at center,
      transparent 0px, transparent 5px,
      rgba(255,255,255,0.025) 5px, rgba(255,255,255,0.025) 6px
    );
  }

  .vinyl-label {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 50%; aspect-ratio: 1; border-radius: 50%;
    background: var(--pink-label);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }

  .vinyl-label::before {
    content: '';
    position: absolute; inset: 0;
    background: url('/logo-negativo.png') center / 55% no-repeat;
    opacity: 0.15;
  }

  .vinyl-label-inner {
    position: relative; text-align: center;
    /* Usar width en vez de padding: un círculo tiene menos altura
       útil cuanto más ancho es el contenido. 62% es el equilibrio. */
    width: 80%;
    font-size: clamp(0.58rem, 1.45vw, 0.82rem);
    color: #111; line-height: 1.45;
    padding-top: 1.5rem;
  }

  .vinyl-label-inner p { margin-bottom: 0.3em; }
  .vinyl-cta { margin-top: 0.5em !important; font-style: italic; opacity: 0.75; }
  .vinyl-date-small { font-weight: 600 !important; letter-spacing: 0.1em; font-size: 1.1em; }

  @media (max-width: 500px) {
    .vinyl-label {
      width: 64%;
    }
    .vinyl-label-inner {
      width: 82%;
      padding-top: 0;
      font-size: 0.6rem;
      line-height: 1.35;
    }
    .vinyl-label-inner p { margin-bottom: 0.2em; }
    .vinyl-cta { margin-top: 0.35em !important; }
  }

  .vinyl-hole {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 8px; height: 8px;
    background: #111; border-radius: 50%;
  }

  /* DETALLES */
  .detalles { background: var(--cream); max-width: 1000px; margin: 0 auto; }

  .detalles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem; max-width: 750px; margin: 0 auto;
  }

  .detalle-item {
    text-align: center; padding: 2.5rem 1.5rem;
    border: 1px solid var(--gray-light); border-radius: 2px;
    transition: border-color 0.3s;
  }

  .detalle-item:hover { border-color: var(--pink); }

  .detalle-icon { display: flex; justify-content: center; margin-bottom: 1.25rem; }
  .detalle-icon svg { width: 26px; height: 26px; color: var(--pink-deep); }

  .detalle-item h3 {
    font-size: 0.65rem; letter-spacing: 0.22em;
    text-transform: uppercase; font-weight: 500;
    color: var(--gray); margin-bottom: 0.5rem;
  }

  .detalle-item p { font-size: 0.85rem; color: var(--gray); font-weight: 300; }

  .detalle-main {
    font-size: clamp(1rem, 2.5vw, 1.3rem) !important;
    color: var(--black) !important;
    font-weight: 300 !important;
    letter-spacing: 0.04em;
    line-height: 1.3; margin-top: 0.25rem;
  }

  /* MAPA */
  .mapa { background: #f0ede8; text-align: center; }

  .mapa-address {
    font-size: 0.8rem; letter-spacing: 0.12em;
    color: var(--gray); margin-bottom: 2.5rem; font-weight: 300;
  }

  .mapa-container {
    max-width: 880px; margin: 0 auto 2rem;
    border-radius: 2px; overflow: hidden;
    box-shadow: 0 4px 30px rgba(0,0,0,0.07); aspect-ratio: 16/9;
  }

  .mapa-container iframe { width: 100%; height: 100%; border: 0; display: block; }

  .mapa-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--black); text-decoration: none;
    border-bottom: 1px solid var(--black); padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .mapa-btn:hover { color: var(--pink-deep); border-color: var(--pink-deep); }
  .mapa-btn svg { width: 13px; height: 13px; }

  /* RSVP */
  .rsvp { background: var(--black); padding: 6rem 1.5rem; }

  .rsvp-inner { max-width: 560px; margin: 0 auto; text-align: center; }

  .rsvp-logo { width: 52px; margin-bottom: 2rem; opacity: 0.9; }

  .rsvp-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 200;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff; margin-bottom: 1rem;
  }

  .rsvp-sub {
    font-size: 0.85rem; color: rgba(255,255,255,0.55);
    font-weight: 200; margin-bottom: 3rem; letter-spacing: 0.06em;
  }

  .rsvp-sub strong { color: var(--pink); font-weight: 300; }

  .rsvp-contacts {
    display: flex; align-items: center;
    justify-content: center; gap: 2.5rem; flex-wrap: wrap;
  }

  .rsvp-contact {
    display: flex; flex-direction: column;
    align-items: center; gap: 0.4rem;
    text-decoration: none; transition: opacity 0.2s;
  }

  .rsvp-contact:hover { opacity: 0.7; }

  .rsvp-name {
    font-size: 0.65rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--pink); font-weight: 300;
  }

  .rsvp-phone {
    font-size: 1.5rem; color: #fff;
    font-weight: 200; letter-spacing: 0.12em;
  }

  .rsvp-divider-v {
    width: 1px; height: 48px;
    background: rgba(255,255,255,0.12);
  }

  /* FOOTER */
  footer {
    background: var(--black);
    border-top: 1px solid rgba(255,255,255,0.05);
    text-align: center; padding: 2rem 1.5rem;
    color: rgba(255,255,255,0.3);
    font-size: 0.72rem; letter-spacing: 0.1em;
  }

  .footer-sub { margin-top: 0.2rem; font-size: 0.62rem; opacity: 0.5; }

  @media (max-width: 600px) {
    .rsvp-divider-v { display: none; }
    .rsvp-contacts { flex-direction: column; gap: 2.5rem; }
    .detalles-grid { grid-template-columns: 1fr; }
    .vn-pills .vn-pill:not(.vn-active) { display: none; }
  }
</style>
