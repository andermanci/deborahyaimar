---
// Variables de entorno públicas (se incrustan en el bundle del cliente).
// Añádelas en Netlify → Site configuration → Environment variables:
//   PUBLIC_CLOUDINARY_CLOUD_NAME   → tu cloud name (ej. "dxyz1234")
//   PUBLIC_CLOUDINARY_PRESET       → nombre del upload preset sin firma (ej. "wedding_invitados")
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? '';
const preset    = import.meta.env.PUBLIC_CLOUDINARY_PRESET ?? '';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/logo-positivo.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Galería — Aimar & Deborah · 12 · 09 · 2026" />
  <title>Fotos · Aimar & Deborah</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,200;0,300;0,400;0,500;1,200;1,300&display=swap" rel="stylesheet" />
  <style>
    @font-face {
      font-family: 'Sloop';
      src: url('/fonts/Sloop-ScriptThree.ttf') format('truetype');
      font-weight: normal; font-style: normal; font-display: swap;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #FAF8F4; --blush: #F5E5ED; --rose: #E8C5D2;
      --pink: #F2B3CE; --dark: #1a1a1a; --gray: #8a7070; --border: #e6d8dc;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--cream); color: var(--dark);
      font-family: 'Raleway', sans-serif; font-weight: 300;
      font-size: 16px; line-height: 1.65; letter-spacing: 0.03em;
      -webkit-font-smoothing: antialiased;
    }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; height: 56px;
      background: rgba(250,248,244,0.92); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { height: 28px; }
    .nav-back {
      font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--gray); text-decoration: none; transition: color 0.2s;
    }
    .nav-back:hover { color: var(--dark); }

    /* HEADER */
    .gl-header { text-align: center; padding: 5rem 1.5rem 3rem; }
    .gl-eyebrow {
      font-size: 0.62rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--pink); margin-bottom: 1.2rem;
    }
    .gl-title {
      font-family: 'Sloop', cursive;
      font-size: clamp(2.8rem, 7vw, 4.5rem);
      font-weight: normal; color: var(--dark);
      line-height: 1.1; margin-bottom: 1rem;
    }
    .gl-sub { font-size: 0.82rem; color: var(--gray); letter-spacing: 0.1em; }

    /* ── GALERÍA OFICIAL ──────────────────────────────────────── */
    .gl-tabs {
      display: flex; justify-content: center; flex-wrap: wrap;
      border-bottom: 1px solid var(--border); padding: 0 1.5rem;
    }
    .gl-tab {
      font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--gray); padding: 1rem 1.4rem;
      cursor: pointer; border: none; background: none;
      border-bottom: 2px solid transparent; margin-bottom: -1px;
      transition: color 0.2s, border-color 0.2s; font-family: inherit;
    }
    .gl-tab:hover { color: var(--dark); }
    .gl-tab.active { color: var(--dark); border-bottom-color: var(--pink); }

    .gl-grid-wrap { padding: 3rem 1.5rem 5rem; max-width: 1100px; margin: 0 auto; }
    .gl-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1px;
    }
    .gl-item { aspect-ratio: 1; overflow: hidden; background: var(--blush); cursor: pointer; }
    .gl-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .gl-item:hover img { transform: scale(1.04); }

    .gl-empty {
      grid-column: 1 / -1;
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; padding: 6rem 2rem; text-align: center;
    }
    .gl-empty-icon { width: 56px; height: 56px; margin-bottom: 2rem; color: var(--rose); }
    .gl-empty-title {
      font-size: 1rem; font-weight: 300; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--dark); margin-bottom: 0.8rem;
    }
    .gl-empty-sub { font-size: 0.82rem; color: var(--gray); max-width: 340px; line-height: 1.8; }
    .gl-date-badge {
      display: inline-block; margin-top: 1.5rem;
      font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--pink); border: 1px solid var(--rose); padding: 0.4rem 1.2rem; border-radius: 50px;
    }

    /* ── SECCIÓN INVITADOS ───────────────────────────────────── */
    .inv-section { background: var(--blush); padding: 6rem 1.5rem; }
    .inv-inner { max-width: 1100px; margin: 0 auto; }

    .inv-header { text-align: center; margin-bottom: 3.5rem; }
    .inv-eyebrow {
      font-size: 0.62rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--pink); margin-bottom: 1rem;
    }
    .inv-title {
      font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 200;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--dark);
      margin-bottom: 0.6rem;
    }
    .inv-sub { font-size: 0.82rem; color: var(--gray); }

    /* Grid de fotos invitados */
    .inv-grid {
      columns: 2; column-gap: 6px;
    }
    @media (min-width: 600px)  { .inv-grid { columns: 3; } }
    @media (min-width: 900px)  { .inv-grid { columns: 4; } }
    @media (min-width: 1200px) { .inv-grid { columns: 5; } }

    .inv-item {
      break-inside: avoid; margin-bottom: 6px;
      position: relative; cursor: pointer; overflow: hidden;
      background: var(--rose);
    }
    .inv-item img {
      width: 100%; display: block;
      transition: transform 0.4s ease;
    }
    .inv-item:hover img { transform: scale(1.04); }
    .inv-item-name {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 0.5rem 0.7rem;
      background: linear-gradient(transparent, rgba(20,10,10,0.55));
      font-size: 0.68rem; letter-spacing: 0.08em; color: #fff;
      opacity: 0; transition: opacity 0.3s;
    }
    .inv-item:hover .inv-item-name { opacity: 1; }

    .inv-empty {
      text-align: center; padding: 4rem 2rem;
      font-size: 0.85rem; color: var(--gray); letter-spacing: 0.06em;
    }
    .inv-loading {
      text-align: center; padding: 3rem;
      font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--gray);
    }
    .inv-refresh {
      text-align: center; margin-top: 2rem;
      font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--gray); opacity: 0.6;
    }
    .inv-refresh span { color: var(--pink); }

    /* Upload form */
    .inv-upload { max-width: 480px; margin: 3.5rem auto 0; }
    .inv-upload-title {
      text-align: center; font-size: 0.72rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--dark); margin-bottom: 1.5rem;
    }
    .uf-label {
      font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--gray); display: block; margin-bottom: 0.4rem;
    }
    .uf-input {
      width: 100%; background: #fff;
      border: 1px solid var(--border); border-radius: 2px;
      color: var(--dark); font-family: inherit; font-size: 0.9rem; font-weight: 300;
      padding: 0.75rem 1rem; transition: border-color 0.2s; margin-bottom: 1rem;
    }
    .uf-input:focus { outline: none; border-color: var(--pink); }
    .uf-input::placeholder { color: rgba(26,26,26,0.3); }

    .uf-dropzone {
      border: 1px dashed var(--border); border-radius: 2px;
      padding: 2rem 1.5rem; text-align: center; cursor: pointer;
      transition: border-color 0.2s, background 0.2s; position: relative;
      background: #fff; margin-bottom: 1rem;
    }
    .uf-dropzone:hover, .uf-dropzone.drag-over {
      border-color: var(--pink); background: rgba(242,179,206,0.06);
    }
    .uf-dropzone input[type="file"] {
      position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }
    .uf-dz-icon { color: var(--pink); margin-bottom: 0.7rem; }
    .uf-dz-text { font-size: 0.82rem; color: var(--gray); line-height: 1.6; }
    .uf-dz-count { font-size: 0.72rem; color: var(--pink); margin-top: 0.4rem; min-height: 1.1em; }

    /* Progress bar */
    .uf-progress-wrap {
      display: none; background: var(--border); border-radius: 2px;
      height: 3px; margin-bottom: 1rem; overflow: hidden;
    }
    .uf-progress-bar {
      height: 100%; background: var(--pink);
      width: 0; transition: width 0.2s;
    }

    .uf-submit {
      width: 100%; background: var(--dark); border: none; border-radius: 2px;
      color: #fff; font-family: inherit;
      font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
      font-weight: 400; padding: 0.9rem 2rem; cursor: pointer;
      transition: opacity 0.2s;
    }
    .uf-submit:hover { opacity: 0.8; }
    .uf-submit:disabled { opacity: 0.4; cursor: not-allowed; }

    .inv-upload-ok {
      display: none; text-align: center; padding: 1.5rem 0;
    }
    .inv-upload-ok p { font-size: 0.85rem; color: var(--dark); letter-spacing: 0.06em; }
    .inv-upload-ok .ok-sub { color: var(--gray); font-size: 0.75rem; margin-top: 0.4rem; }
    .inv-upload-again {
      display: inline-block; margin-top: 1rem;
      font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--pink); cursor: pointer; border-bottom: 1px solid var(--rose);
    }

    /* Lightbox */
    .lightbox {
      display: none; position: fixed; inset: 0; z-index: 1000;
      background: rgba(15,5,5,0.95);
      align-items: center; justify-content: center;
    }
    .lightbox.open { display: flex; }
    .lightbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; }
    .lb-close {
      position: absolute; top: 1.2rem; right: 1.5rem;
      font-size: 1.4rem; color: #fff; cursor: pointer;
      background: none; border: none; opacity: 0.55; transition: opacity 0.2s;
    }
    .lb-close:hover { opacity: 1; }
    .lb-prev, .lb-next {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: #fff; font-size: 2rem;
      cursor: pointer; opacity: 0.4; padding: 1rem; transition: opacity 0.2s;
    }
    .lb-prev:hover, .lb-next:hover { opacity: 1; }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }

    /* Footer */
    footer {
      background: var(--dark); border-top: 1px solid rgba(255,255,255,0.05);
      text-align: center; padding: 2rem 1.5rem;
      color: rgba(255,255,255,0.25); font-size: 0.72rem; letter-spacing: 0.1em;
    }
    .footer-sub { margin-top: 0.2rem; font-size: 0.62rem; opacity: 0.5; }

    /* Entrada de fotos */
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .inv-item { animation: fadeIn 0.4s ease both; }
  </style>
</head>
<body>

  <nav>
    <a href="javascript:history.back()" class="nav-back">← volver</a>
    <img src="/logo-positivo.png" alt="A&D" class="nav-logo" />
    <span style="width:5rem"></span>
  </nav>

  <!-- HEADER -->
  <div class="gl-header">
    <p class="gl-eyebrow">12 · 09 · 2026</p>
    <h1 class="gl-title">Fotos</h1>
    <p class="gl-sub">Aimar & Deborah · Palacio de Murguia</p>
  </div>

  <!-- TABS GALERÍA OFICIAL -->
  <div class="gl-tabs" role="tablist">
    <button class="gl-tab active" data-cat="todas">Todas</button>
    <button class="gl-tab" data-cat="ceremonia">Ceremonia</button>
    <button class="gl-tab" data-cat="cocktail">Cocktail</button>
    <button class="gl-tab" data-cat="comida">Comida</button>
    <button class="gl-tab" data-cat="baile">Baile</button>
    <button class="gl-tab" data-cat="momentos">Momentos</button>
  </div>

  <!-- GALERÍA OFICIAL -->
  <div class="gl-grid-wrap">
    <div class="gl-grid" id="glGrid">
      <div class="gl-empty" id="glEmpty">
        <svg class="gl-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="M21 15l-5-5L5 21"/>
        </svg>
        <p class="gl-empty-title">Las fotos llegarán pronto</p>
        <p class="gl-empty-sub">Después de la boda colgaremos aquí todos los recuerdos del día. Vuelve a partir del 13 de septiembre.</p>
        <span class="gl-date-badge">12 · 09 · 2026</span>
      </div>
    </div>
  </div>

  <!-- LIGHTBOX GALERÍA OFICIAL -->
  <div class="lightbox" id="lightbox">
    <button class="lb-close" id="lbClose">✕</button>
    <button class="lb-prev" id="lbPrev">‹</button>
    <img id="lbImg" src="" alt="" />
    <button class="lb-next" id="lbNext">›</button>
  </div>

  <!-- ── FOTOS DE LOS INVITADOS ─────────────────────────────── -->
  <section class="inv-section">
    <div class="inv-inner">

      <div class="inv-header">
        <p class="inv-eyebrow">El día de la boda</p>
        <h2 class="inv-title">Vuestras fotos</h2>
        <p class="inv-sub">Comparte los momentos que hayas capturado</p>
      </div>

      <!-- Grid de fotos en tiempo real -->
      <div class="inv-grid" id="invGrid">
        <div class="inv-loading" id="invLoading">Cargando…</div>
      </div>
      <p class="inv-refresh" id="invRefresh" style="display:none">
        Se actualiza cada 30 segundos · última vez hace <span id="invTimer">0</span>s
      </p>

      <!-- Lightbox invitados -->
      <div class="lightbox" id="invLightbox">
        <button class="lb-close" id="invLbClose">✕</button>
        <button class="lb-prev" id="invLbPrev">‹</button>
        <img id="invLbImg" src="" alt="" />
        <button class="lb-next" id="invLbNext">›</button>
      </div>

      <!-- Formulario subida -->
      <div class="inv-upload">
        <p class="inv-upload-title">Sube las tuyas</p>

        <form id="invUploadForm">
          <label class="uf-label" for="invNombre">Tu nombre</label>
          <input class="uf-input" type="text" id="invNombre" placeholder="María García" required />

          <label class="uf-label">Fotos</label>
          <div class="uf-dropzone" id="invDropzone">
            <input type="file" id="invFileInput" accept="image/*" multiple />
            <div class="uf-dz-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
            </div>
            <p class="uf-dz-text">Arrastra aquí o toca para seleccionar</p>
            <p class="uf-dz-count" id="invFileCount"></p>
          </div>

          <div class="uf-progress-wrap" id="invProgressWrap">
            <div class="uf-progress-bar" id="invProgressBar"></div>
          </div>

          <button type="submit" class="uf-submit" id="invSubmitBtn">Subir fotos</button>
        </form>

        <div class="inv-upload-ok" id="invUploadOk">
          <p>¡Gracias por compartir!</p>
          <p class="ok-sub">Tus fotos ya están en la galería.</p>
          <span class="inv-upload-again" id="invUploadAgain">Subir más fotos</span>
        </div>
      </div>

    </div>
  </section>

  <footer>
    <p>Aimar & Deborah · 12 · 09 · 2026</p>
    <p class="footer-sub">deborahyaimar.com</p>
  </footer>

<script define:vars={{ cloudName, preset }} is:inline>
  // ── GALERÍA OFICIAL (fotos de los novios) ─────────────────────
  const FOTOS = [];  // Rellenar después de la boda:
  // { src: '/fotos/foto1.jpg', cat: 'ceremonia', alt: 'descripción' }

  const glGrid   = document.getElementById('glGrid');
  const glEmpty  = document.getElementById('glEmpty');
  const lightbox = document.getElementById('lightbox');
  const lbImg    = document.getElementById('lbImg');
  const lbClose  = document.getElementById('lbClose');
  const lbPrev   = document.getElementById('lbPrev');
  const lbNext   = document.getElementById('lbNext');
  let glCat = 'todas';
  let glIdx = 0;

  function glFiltered() {
    return glCat === 'todas' ? FOTOS : FOTOS.filter(f => f.cat === glCat);
  }
  function renderGallery() {
    glGrid.querySelectorAll('.gl-item').forEach(el => el.remove());
    const items = glFiltered();
    glEmpty.style.display = items.length === 0 ? 'flex' : 'none';
    items.forEach((foto, idx) => {
      const div = document.createElement('div');
      div.className = 'gl-item';
      div.innerHTML = `<img src="${foto.src}" alt="${foto.alt}" loading="lazy" />`;
      div.addEventListener('click', () => openLb(lightbox, lbImg, idx, glFiltered));
      glGrid.appendChild(div);
    });
  }
  document.querySelectorAll('.gl-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.gl-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      glCat = btn.dataset.cat;
      renderGallery();
    });
  });

  // Lightbox genérico
  function openLb(box, imgEl, idx, getItems) {
    box._idx = idx; box._getItems = getItems;
    imgEl.src = getItems()[idx].full ?? getItems()[idx].src;
    box.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLb(box) { box.classList.remove('open'); document.body.style.overflow = ''; }
  function stepLb(box, imgEl, dir) {
    const items = box._getItems();
    box._idx = (box._idx + dir + items.length) % items.length;
    imgEl.src = items[box._idx].full ?? items[box._idx].src;
  }
  lbClose.addEventListener('click', () => closeLb(lightbox));
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLb(lightbox); });
  lbPrev.addEventListener('click', () => stepLb(lightbox, lbImg, -1));
  lbNext.addEventListener('click', () => stepLb(lightbox, lbImg,  1));

  renderGallery();

  // ── FOTOS DE INVITADOS ─────────────────────────────────────────
  const invGrid      = document.getElementById('invGrid');
  const invLoading   = document.getElementById('invLoading');
  const invRefresh   = document.getElementById('invRefresh');
  const invTimer     = document.getElementById('invTimer');
  const invLightbox  = document.getElementById('invLightbox');
  const invLbImg     = document.getElementById('invLbImg');
  const invLbClose   = document.getElementById('invLbClose');
  const invLbPrev    = document.getElementById('invLbPrev');
  const invLbNext    = document.getElementById('invLbNext');

  invLbClose.addEventListener('click', () => closeLb(invLightbox));
  invLightbox.addEventListener('click', e => { if (e.target === invLightbox) closeLb(invLightbox); });
  invLbPrev.addEventListener('click', () => stepLb(invLightbox, invLbImg, -1));
  invLbNext.addEventListener('click', () => stepLb(invLightbox, invLbImg,  1));

  document.addEventListener('keydown', e => {
    const box = [lightbox, invLightbox].find(b => b.classList.contains('open'));
    if (!box) return;
    const img = box === lightbox ? lbImg : invLbImg;
    if (e.key === 'ArrowLeft')  stepLb(box, img, -1);
    if (e.key === 'ArrowRight') stepLb(box, img,  1);
    if (e.key === 'Escape')     closeLb(box);
  });

  let invFotos = [];
  let secondsSince = 0;

  function renderInvGrid() {
    invGrid.querySelectorAll('.inv-item').forEach(el => el.remove());
    if (invFotos.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'inv-empty';
      empty.textContent = 'Aún no hay fotos. ¡Sé el primero en subir la tuya!';
      invGrid.appendChild(empty);
      return;
    }
    invFotos.forEach((foto, idx) => {
      const div = document.createElement('div');
      div.className = 'inv-item';
      div.style.animationDelay = `${Math.min(idx, 8) * 40}ms`;
      div.innerHTML = `
        <img src="${foto.thumb}" alt="Foto de ${foto.nombre}" loading="lazy" />
        ${foto.nombre ? `<span class="inv-item-name">${foto.nombre}</span>` : ''}`;
      div.addEventListener('click', () => openLb(invLightbox, invLbImg, idx, () => invFotos));
      invGrid.appendChild(div);
    });
  }

  async function fetchInvFotos(showLoading = false) {
    if (showLoading) invLoading.style.display = 'block';
    try {
      const res  = await fetch('/.netlify/functions/fotos-invitados');
      const data = await res.json();
      if (Array.isArray(data)) {
        invFotos = data;
        renderInvGrid();
        secondsSince = 0;
        invRefresh.style.display = 'block';
        invTimer.textContent = '0';
      }
    } catch {
      if (invFotos.length === 0) {
        invLoading.textContent = 'No se pudo cargar. Comprueba la conexión.';
      }
    } finally {
      if (showLoading) invLoading.style.display = 'none';
    }
  }

  // Primer fetch al cargar
  fetchInvFotos(true);

  // Refresco cada 30 segundos
  setInterval(() => fetchInvFotos(), 30_000);

  // Contador de segundos
  setInterval(() => {
    secondsSince++;
    if (invTimer) invTimer.textContent = String(secondsSince);
  }, 1_000);

  // ── SUBIR FOTOS A CLOUDINARY ───────────────────────────────────
  const uploadForm   = document.getElementById('invUploadForm');
  const fileInput    = document.getElementById('invFileInput');
  const dropzone     = document.getElementById('invDropzone');
  const fileCount    = document.getElementById('invFileCount');
  const progressWrap = document.getElementById('invProgressWrap');
  const progressBar  = document.getElementById('invProgressBar');
  const submitBtn    = document.getElementById('invSubmitBtn');
  const uploadOk     = document.getElementById('invUploadOk');
  const uploadAgain  = document.getElementById('invUploadAgain');
  const nombreInput  = document.getElementById('invNombre');

  fileInput.addEventListener('change', updateCount);
  function updateCount() {
    const n = fileInput.files?.length ?? 0;
    fileCount.textContent = n > 0 ? `${n} foto${n > 1 ? 's' : ''} seleccionada${n > 1 ? 's' : ''}` : '';
  }

  dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag-over'); });
  dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
  dropzone.addEventListener('drop', e => {
    e.preventDefault(); dropzone.classList.remove('drag-over');
    if (e.dataTransfer?.files) { fileInput.files = e.dataTransfer.files; updateCount(); }
  });

  uploadAgain.addEventListener('click', () => {
    uploadOk.style.display = 'none';
    uploadForm.style.display = '';
    uploadForm.reset();
    fileCount.textContent = '';
  });

  uploadForm.addEventListener('submit', async e => {
    e.preventDefault();
    const nombre = nombreInput.value.trim();
    const files  = Array.from(fileInput.files ?? []);
    if (!files.length) { alert('Selecciona al menos una foto.'); return; }
    if (!cloudName || !preset) {
      alert('La subida aún no está configurada. Vuelve el día de la boda.');
      return;
    }

    submitBtn.disabled = true;
    progressWrap.style.display = 'block';
    progressBar.style.width = '0%';

    let uploaded = 0;
    const total  = files.length;

    for (const file of files) {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('upload_preset', preset);
      fd.append('folder', 'wedding/invitados');
      if (nombre) fd.append('context', `nombre=${nombre}`);

      await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`, {
        method: 'POST',
        body: fd,
      });

      uploaded++;
      progressBar.style.width = `${(uploaded / total) * 100}%`;
    }

    submitBtn.disabled = false;
    progressWrap.style.display = 'none';
    uploadForm.style.display = 'none';
    uploadOk.style.display = 'block';

    // Refrescar galería inmediatamente
    await fetchInvFotos();
  });
</script>

</body>
</html>
