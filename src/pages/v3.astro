---
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/logo-positivo.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Aimar & Deborah — 12 · 09 · 2026 · Palacio de Murguia, Astigarraga" />
  <title>Aimar & Deborah · Romántica Natural</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,200;0,300;0,400;1,200;1,300&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- VERSION NAV -->
  <div class="vn">
    <a href="/" class="vn-back">← propuestas</a>
    <div class="vn-pills">
      <a href="/v1" class="vn-pill">01 Clásica</a>
      <a href="/v2" class="vn-pill">02 Oscura</a>
      <a href="/v3" class="vn-pill vn-active">03 Romántica</a>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-inner">
      <div class="hero-photo-wrap">
        <img src="/foto.jpeg" alt="Aimar y Deborah" class="hero-photo" />
      </div>
      <div class="hero-text">
        <p class="hero-label">os invitamos a nuestra boda</p>
        <h1 class="hero-names">
          Aimar<br/>
          <span class="amp">&</span><br/>
          Deborah
        </h1>
        <div class="hero-details">
          <p class="hero-date">12 · 09 · 2026</p>
          <p class="hero-venue">Palacio de Murguia</p>
          <p class="hero-place">Astigarraga · 13:00 h</p>
        </div>
        <img src="/logo-positivo.png" alt="A&D" class="hero-monogram" />
      </div>
    </div>
  </section>

  <!-- MENSAJE -->
  <section class="mensaje" id="invitacion">
    <div class="mensaje-inner">
      <div class="mensaje-deco">
        <div class="deco-ring"></div>
        <div class="deco-ring deco-ring-2"></div>
      </div>
      <p class="mensaje-text">
        Dicen que las mejores canciones nacen de mezclas inesperadas.<br/>
        Dos estilos distintos, dos formas de ser<br/>
        y una canción que encaja a la perfección.
      </p>
      <p class="mensaje-sub">
        Después de un tiempo sonando juntos, hemos decidido<br/>
        que esta canción <em>dure para siempre.</em>
      </p>
      <p class="mensaje-play">Dale al play con nosotros el 12 · 09 · 2026</p>
    </div>
  </section>

  <!-- DETALLES -->
  <section class="detalles" id="detalles">
    <h2 class="section-title">La celebración</h2>
    <div class="deco-line"></div>
    <div class="detalles-grid">
      <div class="det-card">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
        </div>
        <h3>Fecha</h3>
        <p class="det-main">12 de septiembre</p>
        <p class="det-sec">Sábado · 2026</p>
      </div>
      <div class="det-card det-card-center">
        <div class="det-photo-small">
          <img src="/foto.jpeg" alt="Aimar y Deborah" />
        </div>
      </div>
      <div class="det-card">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 3"/>
          </svg>
        </div>
        <h3>Hora</h3>
        <p class="det-main">13:00 h</p>
        <p class="det-sec">de la tarde</p>
      </div>
      <div class="det-card" style="grid-column: 1 / -1;">
        <div class="det-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M12 21s-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-8 12-8 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
        </div>
        <h3>Lugar</h3>
        <p class="det-main">Palacio de Murguia</p>
        <p class="det-sec">Nagusia Kalea, 15 · Astigarraga, Gipuzkoa</p>
      </div>
    </div>
  </section>

  <!-- MAPA -->
  <section class="mapa" id="mapa">
    <h2 class="section-title">Cómo llegar</h2>
    <div class="deco-line"></div>
    <p class="mapa-address">Nagusia Kalea, 15 · 20115 Astigarraga, Gipuzkoa</p>
    <div class="mapa-container">
      <iframe
        src="https://maps.google.com/maps?q=Palacio+de+Murguia,+Astigarraga,+Gipuzkoa&t=&z=16&ie=UTF8&iwloc=&output=embed"
        allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        title="Palacio de Murguia"
      ></iframe>
    </div>
    <a href="https://maps.google.com/?q=Nagusia+Kalea+15,+20115+Astigarraga" target="_blank" rel="noopener noreferrer" class="mapa-btn">
      Abrir en Google Maps →
    </a>
  </section>

  <!-- RSVP -->
  <section class="rsvp" id="confirmacion">
    <div class="rsvp-photo-bg"></div>
    <div class="rsvp-inner">
      <img src="/logo-positivo.png" alt="A&D" class="rsvp-monogram" />
      <h2 class="rsvp-title">¿Contamos contigo?</h2>
      <p class="rsvp-dead">Confírmanos tu asistencia antes del <strong>10 de agosto</strong></p>
      <div class="rsvp-contacts">
        <a href="tel:+34634421876" class="rsvp-card">
          <span class="rsvp-name">Aimar</span>
          <span class="rsvp-phone">634 421 876</span>
        </a>
        <a href="tel:+34644455703" class="rsvp-card">
          <span class="rsvp-name">Deborah</span>
          <span class="rsvp-phone">644 455 703</span>
        </a>
      </div>
    </div>
  </section>

  <footer>
    <p>Aimar & Deborah · 12 · 09 · 2026</p>
    <p class="footer-sub">deborahyaimar.com</p>
  </footer>

</body>
</html>

<style is:global>
  @font-face {
    font-family: 'Sloop';
    src: url('/fonts/Sloop-ScriptThree.ttf') format('truetype');
    font-weight: normal;
    font-display: swap;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FCF8F4;
    --blush: #F5E8EF;
    --rose: #E8C5D2;
    --rosewood: #7A3B50;
    --pink: #E8A5BE;
    --dark: #2a1520;
    --gray: #9a7a85;
    --border: #e4d0d9;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--dark);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.7;
    letter-spacing: 0.03em;
    -webkit-font-smoothing: antialiased;
  }

  /* VERSION NAV */
  .vn {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(252,248,244,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }

  .vn-back {
    color: var(--gray);
    text-decoration: none;
    transition: color 0.2s;
  }
  .vn-back:hover { color: var(--dark); }

  .vn-pills { display: flex; gap: 0.4rem; }

  .vn-pill {
    text-decoration: none;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    color: var(--gray);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    transition: all 0.2s;
  }

  .vn-pill:hover { border-color: var(--pink); color: var(--dark); }

  .vn-active {
    background: var(--rosewood);
    border-color: var(--rosewood);
    color: #fff !important;
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100svh;
    padding-top: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 50%, var(--blush) 0%, var(--cream) 70%);
    z-index: 0;
  }

  .hero-inner {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1100px;
    width: 100%;
    padding: 4rem 5vw;
  }

  .hero-photo-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .hero-photo-wrap::before {
    content: '';
    position: absolute;
    inset: -15px -10px;
    background: var(--rose);
    border-radius: 2px;
    transform: rotate(-2deg);
    z-index: 0;
    opacity: 0.5;
  }

  .hero-photo {
    position: relative; z-index: 1;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center 20%;
    border: 10px solid #fff;
    box-shadow: 0 12px 50px rgba(42,21,32,0.18);
    border-radius: 1px;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 300;
  }

  .hero-names {
    font-family: 'Sloop', cursive;
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: normal;
    line-height: 0.9;
    color: var(--dark);
  }

  .amp {
    color: var(--rosewood);
    font-size: 0.75em;
    opacity: 0.85;
  }

  .hero-details {
    border-left: 2px solid var(--rose);
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hero-date {
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    color: var(--dark);
    font-weight: 400;
  }

  .hero-venue {
    font-size: 0.82rem;
    color: var(--gray);
    font-weight: 300;
  }

  .hero-place {
    font-size: 0.75rem;
    color: var(--gray);
    font-weight: 200;
    letter-spacing: 0.08em;
  }

  .hero-monogram {
    width: 40px;
    opacity: 0.25;
    margin-top: 1rem;
  }

  /* MENSAJE */
  .mensaje {
    background: var(--blush);
    text-align: center;
    padding: 7rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .mensaje-inner {
    max-width: 640px;
    margin: 0 auto;
    position: relative; z-index: 1;
  }

  .mensaje-deco {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
  }

  .deco-ring {
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    border: 1px solid var(--rose);
    opacity: 0.4;
  }

  .deco-ring-2 {
    width: 600px; height: 600px;
    opacity: 0.2;
  }

  .mensaje-text {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    color: var(--dark);
    font-weight: 300;
    font-style: italic;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  .mensaje-sub {
    font-size: 0.95rem;
    color: var(--gray);
    margin-bottom: 2.5rem;
    line-height: 1.8;
    font-weight: 200;
  }

  .mensaje-sub em { color: var(--rosewood); font-style: italic; }

  .mensaje-play {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--rosewood);
    font-weight: 400;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--rosewood);
    border-radius: 100px;
  }

  /* SECTION TITLE */
  .section-title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 200;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dark);
    text-align: center;
    margin-bottom: 1rem;
  }

  .deco-line {
    width: 50px; height: 1px;
    background: var(--pink);
    margin: 0 auto 3.5rem;
  }

  /* DETALLES */
  .detalles {
    background: var(--cream);
    padding: 5rem 2rem;
  }

  .detalles-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .det-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .det-card:hover {
    box-shadow: 0 6px 30px rgba(232,165,190,0.2);
    transform: translateY(-2px);
  }

  .det-card-center {
    padding: 0;
    overflow: hidden;
    border: none;
    background: transparent;
  }

  .det-photo-small {
    width: 120px;
    height: 100%;
    min-height: 140px;
    border: 5px solid #fff;
    box-shadow: 0 4px 20px rgba(42,21,32,0.12);
    transform: rotate(1.5deg);
    overflow: hidden;
    border-radius: 1px;
  }

  .det-photo-small img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 20%;
  }

  .det-icon-wrap {
    display: flex; justify-content: center;
    margin-bottom: 1rem;
  }

  .det-icon-wrap svg {
    width: 24px; height: 24px;
    color: var(--pink);
  }

  .det-card h3 {
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .det-main {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--dark);
    font-weight: 300;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .det-sec {
    font-size: 0.75rem;
    color: var(--gray);
    font-weight: 200;
    letter-spacing: 0.06em;
  }

  /* MAPA */
  .mapa {
    background: var(--blush);
    padding: 5rem 2rem;
    text-align: center;
  }

  .mapa-address {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--gray);
    margin-bottom: 2.5rem;
    font-weight: 200;
  }

  .mapa-container {
    max-width: 880px; margin: 0 auto 2rem;
    border-radius: 3px; overflow: hidden;
    border: 6px solid #fff;
    box-shadow: 0 8px 40px rgba(42,21,32,0.1);
    aspect-ratio: 16/9;
  }

  .mapa-container iframe { width: 100%; height: 100%; border: 0; display: block; }

  .mapa-btn {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rosewood);
    text-decoration: none;
    font-weight: 400;
    border-bottom: 1px solid var(--rosewood);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .mapa-btn:hover { opacity: 0.65; }

  /* RSVP */
  .rsvp {
    background: var(--dark);
    padding: 7rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .rsvp-photo-bg {
    position: absolute; inset: 0;
    background: url('/foto.jpeg') center / cover;
    opacity: 0.08;
    filter: grayscale(100%);
  }

  .rsvp-inner {
    position: relative; z-index: 1;
    max-width: 580px; margin: 0 auto;
  }

  .rsvp-monogram {
    width: 48px;
    filter: invert(1);
    opacity: 0.4;
    margin-bottom: 2rem;
  }

  .rsvp-title {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 200;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1rem;
  }

  .rsvp-dead {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 3rem;
    font-weight: 200;
    letter-spacing: 0.06em;
  }

  .rsvp-dead strong { color: var(--rose); font-weight: 300; }

  .rsvp-contacts {
    display: flex; gap: 1.5rem;
    justify-content: center; flex-wrap: wrap;
  }

  .rsvp-card {
    display: flex; flex-direction: column; gap: 0.5rem;
    text-decoration: none;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px;
    padding: 1.75rem 2.5rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .rsvp-card:hover {
    border-color: var(--rose);
    background: rgba(232,197,210,0.08);
  }

  .rsvp-name {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    font-weight: 300;
  }

  .rsvp-phone {
    font-size: 1.4rem;
    color: #fff;
    font-weight: 200;
    letter-spacing: 0.12em;
  }

  /* FOOTER */
  footer {
    background: var(--dark);
    border-top: 1px solid rgba(255,255,255,0.05);
    text-align: center;
    padding: 2rem 1.5rem;
    color: rgba(255,255,255,0.25);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  .footer-sub { margin-top: 0.2rem; font-size: 0.62rem; opacity: 0.5; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .hero-details { border-left: none; border-top: 1px solid var(--rose); padding: 1rem 0 0; align-items: center; }
    .hero-monogram { margin: 0 auto; }
    .hero-photo { max-width: 280px; }
    .detalles-grid { grid-template-columns: 1fr; }
    .det-card-center { display: none; }
    .vn-pills .vn-pill:not(.vn-active) { display: none; }
  }
</style>
